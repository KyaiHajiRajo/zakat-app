<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabButtons = Array.from(document.querySelectorAll(".rtd-list-tab"));
    const tabPanels = Array.from(document.querySelectorAll(".rtd-tab-panel"));
    const tabActions = Array.from(document.querySelectorAll(".rtd-tab-action"));
    const listTitle = document.getElementById("rtdListTitle");
    const listSubtitle = document.getElementById("rtdListSubtitle");

    const setActiveTab = (button) => {
      if (!button) return;
      const targetId = button.getAttribute("data-tab-target");

      tabButtons.forEach((item) => item.classList.remove("is-active"));
      tabPanels.forEach((item) => item.classList.remove("is-active"));
      tabActions.forEach((item) => item.classList.remove("is-active"));

      button.classList.add("is-active");

      const targetPanel = document.getElementById(targetId);
      if (targetPanel) {
        targetPanel.classList.add("is-active");
      }

      if (listTitle) {
        listTitle.textContent = button.getAttribute("data-tab-title") || "";
      }

      if (listSubtitle) {
        listSubtitle.textContent =
          button.getAttribute("data-tab-subtitle") || "";
      }

      tabActions
        .filter((item) => item.getAttribute("data-tab-action") === targetId)
        .forEach((item) => item.classList.add("is-active"));
    };

    if (tabButtons.length > 0) {
      tabButtons.forEach((button) => {
        button.addEventListener("click", () => setActiveTab(button));
      });
      setActiveTab(
        tabButtons.find((button) => button.classList.contains("is-active")) ||
          tabButtons[0]
      );
    }

    document.querySelectorAll(".delete-form").forEach((form) => {
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        const muzakkiName = this.getAttribute("data-name") || "muzakki ini";

        showDeleteConfirm(
          muzakkiName,
          "Yakin ingin menghapus data muzakki ini?"
        ).then((result) => {
          if (result.isConfirmed) {
            this.submit();
          }
        });
      });
    });
  });
</script>

