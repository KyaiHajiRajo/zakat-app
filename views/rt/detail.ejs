<%- include('../layouts/header', { title: title, bodyClass: 'bg-slate-50 min-h-screen', currentPage: 'rt' }) %>

<%
  const formatRupiah = (value) => {
    const numericValue = Number(value);
    if (!Number.isFinite(numericValue)) {
      return "0";
    }
    return Math.round(numericValue).toLocaleString("id-ID");
  };

  const formatKg = (value) => {
    const numericValue = Number(value);
    if (!Number.isFinite(numericValue)) {
      return "0";
    }
    return numericValue.toLocaleString("id-ID", {
      minimumFractionDigits: 0,
      maximumFractionDigits: 2,
    });
  };

  const formatTanggal = (tanggalValue, createdAtValue) => {
    const sourceValue = tanggalValue || createdAtValue;
    if (!sourceValue) {
      return "-";
    }

    const parsedDate = new Date(sourceValue);
    if (Number.isNaN(parsedDate.getTime())) {
      return "-";
    }

    return parsedDate.toLocaleDateString("id-ID", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    });
  };

  const totalMuzakki = Number(stats.total_muzakki || 0);
  const totalMustahik = Number(stats.total_mustahik || 0);
  const totalLunas = Number(stats.lunas || 0);
  const totalBelumLunas = Number(stats.belum_lunas || 0);
  const totalZakat = Number(stats.total_zakat || 0);
  const totalJumlahBayar = Number(stats.total_bayar || 0);
  const totalJumlahBerasKg = Number(stats.total_jumlah_beras_kg || 0);
  const totalMuzakkiUang = Number(stats.total_muzakki_uang || 0);
  const totalMuzakkiBeras = Number(stats.total_muzakki_beras || 0);
  const completionRate =
    totalMuzakki > 0 ? Math.round((totalLunas / totalMuzakki) * 100) : 0;
  const averagePerMuzakki =
    totalMuzakki > 0 ? Math.round(totalZakat / totalMuzakki) : 0;
%>

<div class="rtd-page">
  <section class="rtd-hero">
    <div class="rtd-hero-left">
      <a href="/rt" class="rtd-back-link">
        <i class="fas fa-arrow-left"></i>
        Kembali ke Data RT
      </a>
      <h1 class="rtd-title">Detail <%= rt.nomor_rt %></h1>
      <p class="rtd-subtitle">
        Ringkasan data RT, status pembayaran, dan daftar muzakki ditampilkan
        dalam satu halaman yang mudah dibaca.
      </p>
      <div class="rtd-meta">
        <span><i class="fas fa-user-tie"></i> Ketua RT: <%= rt.ketua_rt %></span>
        <span><i class="fas fa-note-sticky"></i> <%= rt.keterangan || 'Tanpa keterangan tambahan' %></span>
      </div>
    </div>
    <div class="rtd-hero-actions">
      <a href="/rt/<%= rt.id %>/edit" class="rtd-btn rtd-btn-solid">
        <i class="fas fa-pen"></i>
        Edit RT
      </a>
      <a href="/muzakki/create?rt_id=<%= rt.id %>" class="rtd-btn rtd-btn-soft">
        <i class="fas fa-user-plus"></i>
        Tambah Muzakki
      </a>
    </div>
  </section>

  <section class="rtd-overview-grid">
    <article class="rtd-overview-card">
      <div class="rtd-overview-head">
        <div class="rtd-overview-icon">
          <i class="fas fa-map-marker-alt"></i>
        </div>
        <div>
          <h2>Informasi RT</h2>
          <p>Data dasar wilayah RT yang sedang dipantau</p>
        </div>
      </div>
      <div class="rtd-info-list">
        <div class="rtd-info-item">
          <span>Nomor RT</span>
          <strong><%= rt.nomor_rt %></strong>
        </div>
        <div class="rtd-info-item">
          <span>Ketua RT</span>
          <strong><%= rt.ketua_rt %></strong>
        </div>
        <div class="rtd-info-item">
          <span>Keterangan</span>
          <strong><%= rt.keterangan || '-' %></strong>
        </div>
      </div>
    </article>

    <article class="rtd-overview-card">
      <div class="rtd-overview-head">
        <div class="rtd-overview-icon rtd-overview-icon-green">
          <i class="fas fa-chart-line"></i>
        </div>
        <div>
          <h2>Progres Pembayaran</h2>
          <p>Persentase penyelesaian zakat muzakki RT <%= rt.nomor_rt %></p>
        </div>
      </div>
      <div class="rtd-progress-wrap">
        <div class="rtd-progress-label">
          <span>Progress Lunas</span>
          <strong><%= completionRate %>%</strong>
        </div>
        <div class="rtd-progress-bar">
          <span style="width: <%= completionRate %>%"></span>
        </div>
      </div>
      <div class="rtd-progress-summary">
        <div>
          <small>Lunas</small>
          <strong><%= totalLunas %></strong>
        </div>
        <div>
          <small>Belum Lunas</small>
          <strong><%= totalBelumLunas %></strong>
        </div>
        <div>
          <small>Rata-rata Zakat</small>
          <strong>Rp <%= formatRupiah(averagePerMuzakki) %></strong>
        </div>
      </div>
    </article>
  </section>

  <section class="rtd-stats-grid">
    <article class="rtd-stat-card">
      <div class="rtd-stat-icon rtd-stat-icon-blue"><i class="fas fa-users"></i></div>
      <div>
        <div class="rtd-stat-value"><%= totalMuzakki %></div>
        <div class="rtd-stat-label">Total Muzakki</div>
      </div>
    </article>
    <article class="rtd-stat-card">
      <div class="rtd-stat-icon rtd-stat-icon-teal"><i class="fas fa-coins"></i></div>
      <div>
        <div class="rtd-stat-value">Rp <%= formatRupiah(totalJumlahBayar) %></div>
        <div class="rtd-stat-label">Total Jumlah Bayar</div>
      </div>
    </article>
    <article class="rtd-stat-card">
      <div class="rtd-stat-icon rtd-stat-icon-green"><i class="fas fa-wheat-awn"></i></div>
      <div>
        <div class="rtd-stat-value"><%= formatKg(totalJumlahBerasKg) %> Liter</div>
        <div class="rtd-stat-label">Total Jumlah Beras</div>
      </div>
    </article>
    <article class="rtd-stat-card rtd-stat-card-split">
      <div class="rtd-stat-icon rtd-stat-icon-indigo"><i class="fas fa-chart-pie"></i></div>
      <div class="rtd-stat-split-content">
        <div class="rtd-stat-split-head">
          <div class="rtd-stat-split-title">Jenis Zakat</div>
        </div>
        <div class="rtd-stat-split-row">
          <span class="rtd-stat-split-label rtd-stat-split-label-uang">Zakat Uang</span>
          <strong class="rtd-stat-split-value"><%= totalMuzakkiUang %> muzakki</strong>
        </div>
        <div class="rtd-stat-split-row">
          <span class="rtd-stat-split-label rtd-stat-split-label-beras">Zakat Beras</span>
          <strong class="rtd-stat-split-value"><%= totalMuzakkiBeras %> muzakki</strong>
        </div>
      </div>
    </article>
  </section>

  <section class="rtd-list-panel">
    <div class="rtd-list-head">
      <div>
        <h2 id="rtdListTitle">Daftar Muzakki</h2>
        <p id="rtdListSubtitle"><%= totalMuzakki %> data muzakki terdaftar pada RT <%= rt.nomor_rt %></p>
      </div>
      <div class="rtd-list-head-controls">
        <div class="rtd-list-tabs" role="tablist" aria-label="Pilih data RT">
          <button
            type="button"
            class="rtd-list-tab is-active"
            data-tab-target="rtdTabMuzakki"
            data-tab-title="Daftar Muzakki"
            data-tab-subtitle="<%= totalMuzakki %> data muzakki terdaftar pada RT <%= rt.nomor_rt %>"
          >
            Muzakki
          </button>
          <button
            type="button"
            class="rtd-list-tab"
            data-tab-target="rtdTabMustahik"
            data-tab-title="Daftar Mustahik"
            data-tab-subtitle="<%= totalMustahik %> data mustahik terdaftar pada RT <%= rt.nomor_rt %>"
          >
            Mustahik
          </button>
        </div>
        <a
          href="/muzakki/create?rt_id=<%= rt.id %>"
          class="rtd-btn rtd-btn-solid rtd-btn-sm rtd-tab-action is-active"
          data-tab-action="rtdTabMuzakki"
        >
          <i class="fas fa-plus"></i>
          Tambah Muzakki
        </a>
        <a
          href="/mustahik/create"
          class="rtd-btn rtd-btn-solid rtd-btn-sm rtd-tab-action"
          data-tab-action="rtdTabMustahik"
        >
          <i class="fas fa-user-plus"></i>
          Tambah Mustahik
        </a>
      </div>
    </div>

    <div id="rtdTabMuzakki" class="rtd-tab-panel is-active">
      <% if (muzakkiList.length > 0) { %>
        <div class="rtd-table-wrap">
          <table class="rtd-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Nama Muzakki</th>
                <th>Jenis Zakat</th>
                <th>Kewajiban Zakat</th>
                <th>Tanggal</th>
                <th class="rtd-align-right">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% muzakkiList.forEach(function(muzakki, index) { %>
                <tr>
                  <td>
                    <strong><%= index + 1 %></strong>
                  </td>
                  <td>
                    <div class="rtd-name-cell">
                      <div class="rtd-name-icon"><i class="fas fa-user"></i></div>
                      <div>
                        <strong><%= muzakki.nama_muzakki_list || 'Muzakki #' + muzakki.id %></strong>
                        <small><%= muzakki.jumlah_jiwa %> jiwa</small>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="rtd-badge <%= muzakki.jenis_zakat === 'uang' ? 'rtd-badge-info' : 'rtd-badge-success' %>">
                      <%= muzakki.jenis_zakat === 'uang' ? 'Uang' : 'Beras' %>
                    </span>
                  </td>
                  <td>
                    <div class="rtd-stack-text">
                      <% if (muzakki.jenis_zakat === 'uang') { %>
                        <strong>Rp <%= formatRupiah(muzakki.jumlah_uang_safe) %></strong>
                      <% } else { %>
                        <strong><%= formatKg(muzakki.jumlah_beras_kg_safe) %> Liter</strong>
                      <% } %>
                    </div>
                  </td>
                  <td>
                    <div class="rtd-stack-text">
                      <strong><%= formatTanggal(muzakki.tanggal, muzakki.created_at) %></strong>
                    </div>
                  </td>
                  <td class="rtd-align-right">
                    <div class="rtd-action-row">
                      <a href="/muzakki/<%= muzakki.id %>/edit" class="rtd-icon-btn rtd-icon-btn-edit" title="Edit Muzakki">
                        <i class="fas fa-edit"></i>
                      </a>
                      <form
                        method="POST"
                        action="/muzakki/<%= muzakki.id %>?_method=DELETE"
                        class="delete-form"
                        data-name="<%= muzakki.nama_muzakki_list %>"
                      >
                        <button type="submit" class="rtd-icon-btn rtd-icon-btn-delete" title="Hapus Muzakki">
                          <i class="fas fa-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="rtd-mobile-list">
          <% muzakkiList.forEach(function(muzakki) { %>
            <article class="rtd-mobile-card">
              <div class="rtd-mobile-top">
                <div>
                  <h3><%= muzakki.nama_muzakki_list || 'Muzakki #' + muzakki.id %></h3>
                  <p><%= muzakki.jenis_zakat === 'uang' ? 'Zakat Uang' : 'Zakat Beras' %></p>
                </div>
                <% if (muzakki.status === 'lunas') { %>
                  <span class="rtd-badge rtd-badge-success">Lunas</span>
                <% } else { %>
                  <span class="rtd-badge rtd-badge-danger">Belum Lunas</span>
                <% } %>
              </div>
              <div class="rtd-mobile-grid">
                <div>
                  <small>Jumlah Jiwa</small>
                  <strong><%= muzakki.jumlah_jiwa %> jiwa</strong>
                </div>
                <div>
                  <small>Kewajiban</small>
                  <% if (muzakki.jenis_zakat === 'uang') { %>
                    <strong>Rp <%= formatRupiah(muzakki.jumlah_uang_safe) %></strong>
                  <% } else { %>
                    <strong><%= formatKg(muzakki.jumlah_beras_kg_safe) %> Liter</strong>
                  <% } %>
                </div>
                <div>
                  <small>Pembayaran</small>
                  <strong>Rp <%= formatRupiah(muzakki.jumlah_bayar_safe) %></strong>
                </div>
                <div>
                  <small>Kembalian</small>
                  <strong>Rp <%= formatRupiah(muzakki.kembalian_safe) %></strong>
                </div>
              </div>
              <div class="rtd-mobile-actions">
                <a href="/muzakki/<%= muzakki.id %>/edit" class="rtd-btn rtd-btn-soft rtd-btn-sm">
                  <i class="fas fa-edit"></i>
                  Edit
                </a>
                <form
                  method="POST"
                  action="/muzakki/<%= muzakki.id %>?_method=DELETE"
                  class="delete-form"
                  data-name="<%= muzakki.nama_muzakki_list %>"
                >
                  <button type="submit" class="rtd-btn rtd-btn-danger rtd-btn-sm">
                    <i class="fas fa-trash"></i>
                    Hapus
                  </button>
                </form>
              </div>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="rtd-empty-state">
          <i class="fas fa-users"></i>
          <h3>Belum ada data muzakki</h3>
          <p>Silakan tambahkan muzakki pertama untuk RT <%= rt.nomor_rt %>.</p>
          <a href="/muzakki/create?rt_id=<%= rt.id %>" class="rtd-btn rtd-btn-solid">
            <i class="fas fa-plus"></i>
            Tambah Muzakki
          </a>
        </div>
      <% } %>
    </div>

    <div id="rtdTabMustahik" class="rtd-tab-panel">
      <% if (mustahikList.length > 0) { %>
        <div class="rtd-table-wrap">
          <table class="rtd-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Nama Mustahik</th>
                <th>Kategori</th>
                <th>Tanggal</th>
              </tr>
            </thead>
            <tbody>
              <% mustahikList.forEach(function(mustahik, index) { %>
                <tr>
                  <td>
                    <strong><%= index + 1 %></strong>
                  </td>
                  <td>
                    <div class="rtd-name-cell">
                      <div class="rtd-name-icon rtd-name-icon-mustahik"><i class="fas fa-user-heart"></i></div>
                      <div>
                        <strong><%= mustahik.nama_mustahik_list || 'Mustahik #' + mustahik.id %></strong>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="rtd-badge rtd-badge-purple">
                      <%= mustahik.kategori || '-' %>
                    </span>
                  </td>
                  <td>
                    <div class="rtd-stack-text">
                      <strong><%= formatTanggal(mustahik.created_at, mustahik.created_at) %></strong>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="rtd-mobile-list">
          <% mustahikList.forEach(function(mustahik) { %>
            <article class="rtd-mobile-card">
              <div class="rtd-mobile-top">
                <div>
                  <h3><%= mustahik.nama_mustahik_list || 'Mustahik #' + mustahik.id %></h3>
                  <p>Mustahik RT <%= rt.nomor_rt %></p>
                </div>
                <span class="rtd-badge rtd-badge-purple"><%= mustahik.kategori || '-' %></span>
              </div>
              <div class="rtd-mobile-grid rtd-mobile-grid-single">
                <div>
                  <small>Tanggal</small>
                  <strong><%= formatTanggal(mustahik.created_at, mustahik.created_at) %></strong>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="rtd-empty-state">
          <i class="fas fa-user-friends"></i>
          <h3>Belum ada data mustahik</h3>
          <p>Silakan tambahkan mustahik pertama untuk RT <%= rt.nomor_rt %>.</p>
          <a href="/mustahik/create" class="rtd-btn rtd-btn-solid">
            <i class="fas fa-user-plus"></i>
            Tambah Mustahik
          </a>
        </div>
      <% } %>
    </div>
  </section>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

  .rtd-page {
    font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
    padding: 18px;
    display: grid;
    gap: 14px;
  }

  .rtd-hero {
    background: linear-gradient(128deg, #0f3d73 0%, #12588f 45%, #0f766e 100%);
    border-radius: 20px;
    padding: 20px;
    color: #f8fbff;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 14px;
    flex-wrap: wrap;
    box-shadow: 0 16px 30px rgba(15, 61, 115, 0.22);
  }

  .rtd-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #dbeafe;
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .rtd-back-link:hover {
    color: #ffffff;
  }

  .rtd-title {
    margin: 0;
    font-family: "Fraunces", "Georgia", serif;
    font-size: clamp(1.35rem, 2.4vw, 2.05rem);
    line-height: 1.2;
  }

  .rtd-subtitle {
    margin: 9px 0 0;
    color: rgba(240, 249, 255, 0.92);
    max-width: 700px;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .rtd-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .rtd-meta span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    font-size: 0.74rem;
    background: rgba(255, 255, 255, 0.12);
  }

  .rtd-hero-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 175px;
  }

  .rtd-btn {
    border: none;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .rtd-btn:hover {
    transform: translateY(-1px);
  }

  .rtd-btn-solid {
    background: #ffffff;
    color: #1d4ed8;
    box-shadow: 0 8px 16px rgba(255, 255, 255, 0.22);
  }

  .rtd-btn-soft {
    background: rgba(255, 255, 255, 0.16);
    color: #f0f9ff;
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .rtd-btn-danger {
    background: #fee2e2;
    color: #b91c1c;
    border: 1px solid #fecaca;
  }

  .rtd-btn-sm {
    padding: 7px 10px;
    font-size: 0.75rem;
  }

  .rtd-overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 12px;
  }

  .rtd-overview-card {
    background: #ffffff;
    border: 1px solid #dbe5f0;
    border-radius: 16px;
    padding: 14px;
    box-shadow: 0 8px 16px rgba(15, 42, 79, 0.06);
  }

  .rtd-overview-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .rtd-overview-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    color: #ffffff;
    background: linear-gradient(135deg, #1d4ed8, #1e40af);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
  }

  .rtd-overview-icon-green {
    background: linear-gradient(135deg, #0f766e, #0d9488);
  }

  .rtd-overview-head h2 {
    margin: 0;
    font-size: 0.92rem;
    color: #0f172a;
  }

  .rtd-overview-head p {
    margin: 3px 0 0;
    font-size: 0.76rem;
    color: #64748b;
  }

  .rtd-info-list {
    display: grid;
    gap: 8px;
  }

  .rtd-info-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 9px 10px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #f8fafc;
  }

  .rtd-info-item span {
    font-size: 0.74rem;
    color: #64748b;
    font-weight: 700;
  }

  .rtd-info-item strong {
    font-size: 0.8rem;
    color: #0f172a;
    text-align: right;
  }

  .rtd-progress-wrap {
    margin-bottom: 10px;
  }

  .rtd-progress-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
    font-size: 0.74rem;
    color: #475569;
    font-weight: 700;
  }

  .rtd-progress-bar {
    width: 100%;
    height: 8px;
    border-radius: 999px;
    background: #e2e8f0;
    overflow: hidden;
  }

  .rtd-progress-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #16a34a, #10b981);
  }

  .rtd-progress-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .rtd-progress-summary div {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #f8fafc;
    padding: 8px;
    text-align: center;
  }

  .rtd-progress-summary small {
    display: block;
    font-size: 0.69rem;
    color: #64748b;
    margin-bottom: 3px;
  }

  .rtd-progress-summary strong {
    display: block;
