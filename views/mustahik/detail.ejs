<%- include('../layouts/header', { title: title, bodyClass: 'bg-gray-50 min-h-screen', currentPage: 'mustahik' }) %>

<div class="max-w-full mx-auto px-1 sm:px-2 lg:px-3 mustahik-detail-page">
  <!-- Header -->
  <div class="mb-8 detail-hero">
    <div class="detail-hero-content">
      <div class="detail-hero-title">
        <a href="/mustahik" class="text-gray-500 hover:text-gray-700 mr-4">
          <i class="fas fa-arrow-left text-lg"></i>
        </a>
        <div>
          <h1 class="text-3xl font-bold text-gray-900">
            <i class="fas fa-user-friends mr-2 text-primary-600"></i>Detail
            Mustahik
          </h1>
          <p class="text-gray-600 mt-1">Informasi lengkap penerima zakat</p>
        </div>
      </div>
      <div class="detail-hero-kpis">
        <div class="detail-hero-kpi">
          <span>Total Distribusi</span>
          <strong><%= distributions.length %></strong>
        </div>
        <div class="detail-hero-kpi">
          <span>Kategori</span>
          <strong><%= (mustahik.kategori || '-').replace(/_/g, ' ') %></strong>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 detail-layout">
    <!-- Main Info -->
    <div class="lg:col-span-2 detail-main">
      <!-- Basic Information -->
      <div class="bg-white shadow-sm rounded-lg mb-6 detail-card detail-card-primary">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">
            <i class="fas fa-info-circle mr-2 text-primary-600"></i>Informasi
            Dasar
          </h2>
        </div>
        <div class="p-6">
          <div class="flex items-center mb-6 detail-profile-row">
            <div class="flex-shrink-0 h-20 w-20 detail-profile-avatar">
              <div
                class="h-20 w-20 rounded-full bg-gradient-to-r from-purple-400 to-pink-400 flex items-center justify-center detail-profile-avatar-inner"
              >
                <span class="text-2xl font-bold text-white">
                  <%= mustahik.nama.charAt(0).toUpperCase() %>
                </span>
              </div>
            </div>
            <div class="ml-6 detail-profile-content">
              <h3 class="text-2xl font-bold text-gray-900 detail-profile-name">
                <%= mustahik.nama %>
              </h3>
              <p class="text-gray-500 detail-profile-rt">
                <% if (mustahik.rt_nama) { %>
                <i class="fas fa-home mr-1"></i>RT <%= mustahik.rt_nama %> <% }
                else { %> <i class="fas fa-minus mr-1"></i>Tidak terdaftar di RT
                <% } %>
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 detail-meta-grid">
            <div class="detail-meta-item">
              <label class="block text-sm font-medium text-gray-500 mb-1 detail-meta-label"
                >Kategori Mustahik</label
              >
              <div class="flex items-center detail-meta-value">
                <span
                  class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <% if (mustahik.kategori === 'fakir') { %>bg-red-100 text-red-800<% } else if (mustahik.kategori === 'miskin') { %>bg-orange-100 text-orange-800<% } else if (mustahik.kategori === 'amil') { %>bg-green-100 text-green-800<% } else if (mustahik.kategori === 'mualaf') { %>bg-blue-100 text-blue-800<% } else if (mustahik.kategori === 'fisabilillah') { %>bg-purple-100 text-purple-800<% } else { %>bg-gray-100 text-gray-800<% } %>"
                >
                  <% if (mustahik.kategori === 'fakir') { %>
                  <i class="fas fa-exclamation-triangle mr-2"></i>Fakir <% }
                  else if (mustahik.kategori === 'miskin') { %>
                  <i class="fas fa-coins mr-2"></i>Miskin <% } else if
                  (mustahik.kategori === 'amil') { %>
                  <i class="fas fa-hands mr-2"></i>Amil <% } else if
                  (mustahik.kategori === 'mualaf') { %>
                  <i class="fas fa-heart mr-2"></i>Mualaf <% } else if
                  (mustahik.kategori === 'fisabilillah') { %>
                  <i class="fas fa-moon mr-2"></i>Fisabilillah <% } else if
                  (mustahik.kategori === 'ibnu_sabil') { %>
                  <i class="fas fa-route mr-2"></i>Ibnu Sabil <% } else if
                  (mustahik.kategori === 'gharimin') { %>
                  <i class="fas fa-credit-card mr-2"></i>Gharimin <% } else if
                  (mustahik.kategori === 'riqab') { %>
                  <i class="fas fa-unlock mr-2"></i>Riqab <% } else { %>
                  <i class="fas fa-user mr-2"></i><%= mustahik.kategori %> <% }
                  %>
                </span>
              </div>
            </div>

            <div class="detail-meta-item">
              <label class="block text-sm font-medium text-gray-500 mb-1 detail-meta-label"
                >Tanggal Daftar</label
              >
              <p class="text-sm text-gray-900 detail-meta-date">
                <i class="fas fa-calendar mr-2"></i>
                <%= new Date(mustahik.created_at).toLocaleDateString('id-ID', {
                day: 'numeric', month: 'long', year: 'numeric' }) %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Distribution History -->
      <div class="bg-white shadow-sm rounded-lg detail-card detail-card-secondary">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">
            <i class="fas fa-history mr-2 text-primary-600"></i>Riwayat
            Distribusi Zakat
          </h2>
        </div>

        <% if (distributions.length === 0) { %>
        <div class="text-center py-12">
          <i class="fas fa-share-alt text-gray-400 text-4xl mb-4"></i>
          <h3 class="text-lg font-medium text-gray-900 mb-2">
            Belum ada distribusi
          </h3>
          <p class="text-gray-500 mb-6">
            Mustahik ini belum pernah menerima distribusi zakat
          </p>
          <a
            href="/distribusi/create?mustahik_id=<%= mustahik.id %>"
            class="btn-primary"
          >
            <i class="fas fa-plus mr-2"></i>Buat Distribusi
          </a>
        </div>
        <% } else { %>
        <div class="detail-history-summary">
          <div class="detail-history-summary-item">
            <i class="fas fa-list"></i>
            <span><%= distributions.length %> riwayat distribusi</span>
          </div>
          <div class="detail-history-summary-item">
            <i class="fas fa-user-check"></i>
            <span>Status terakhir:
              <strong><%= distributions[0].status.charAt(0).toUpperCase() + distributions[0].status.slice(1) %></strong>
            </span>
          </div>
        </div>
        <div class="overflow-x-auto detail-table-wrap">
          <table class="min-w-full divide-y divide-gray-200 detail-table">
            <thead class="bg-gray-50">
              <tr>
                <th
                  class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                >
                  Tanggal
                </th>
                <th
                  class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                >
                  Jenis & Jumlah
                </th>
                <th
                  class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                >
                  Status
                </th>
                <th
                  class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                >
                  PIC
                </th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% distributions.forEach(d => { %>
              <tr class="hover:bg-gray-50 detail-history-row">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 detail-history-date">
                  <%= new Date(d.created_at).toLocaleDateString('id-ID') %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap detail-history-amount-cell">
                  <div class="text-sm text-gray-900 detail-history-amount">
                    <% if (d.jenis_zakat === 'beras') { %>
                    <i class="fas fa-seedling text-green-600 mr-1"></i>
                    <%= parseFloat(d.jumlah).toLocaleString('id-ID') %> kg Beras
                    <% } else { %>
                    <i class="fas fa-coins text-yellow-600 mr-1"></i>
                    Rp <%= parseFloat(d.jumlah).toLocaleString('id-ID') %> <% }
                    %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span
                    class="inline-flex px-2 py-1 text-xs font-semibold rounded-full detail-status-badge status-<%= d.status %> <% if (d.status === 'diterima') { %>bg-green-100 text-green-800<% } else if (d.status === 'disalurkan') { %>bg-blue-100 text-blue-800<% } else if (d.status === 'pending') { %>bg-yellow-100 text-yellow-800<% } else { %>bg-red-100 text-red-800<% } %>"
                  >
                    <%= d.status.charAt(0).toUpperCase() + d.status.slice(1) %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 detail-history-pic">
                  <%= d.user_nama || 'System' %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="lg:col-span-1 detail-side">
      <!-- Quick Actions -->
      <div class="bg-white shadow-sm rounded-lg mb-6 detail-card detail-card-actions">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900">
            <i class="fas fa-bolt mr-2 text-primary-600"></i>Aksi Cepat
          </h3>
        </div>
        <div class="p-6 space-y-3 detail-actions-list">
          <a
            href="/mustahik/edit/<%= mustahik.id %>"
            class="btn-secondary w-full text-center"
          >
            <i class="fas fa-edit mr-2"></i>Edit Data
          </a>
          <a
            href="/distribusi/create?mustahik_id=<%= mustahik.id %>"
            class="btn-primary w-full text-center"
          >
            <i class="fas fa-share-alt mr-2"></i>Buat Distribusi
          </a>
          <form
            method="POST"
            action="/mustahik/delete/<%= mustahik.id %>?_method=DELETE"
            id="deleteForm"
          >
            <button type="submit" class="btn-danger w-full">
              <i class="fas fa-trash mr-2"></i>Hapus Data
            </button>
          </form>
        </div>
      </div>

      <!-- Statistics -->
      <div class="bg-white shadow-sm rounded-lg detail-card detail-card-stats">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900">
            <i class="fas fa-chart-pie mr-2 text-primary-600"></i>Statistik
          </h3>
        </div>
        <div class="p-6">
          <div class="space-y-4 detail-stat-list">
            <div class="flex justify-between detail-stat-item">
              <span class="text-sm text-gray-500">Total Distribusi</span>
              <span class="text-sm font-medium text-gray-900"
                ><%= distributions.length %></span
              >
            </div>
            <div class="flex justify-between detail-stat-item">
              <span class="text-sm text-gray-500">Beras Diterima</span>
              <span class="text-sm font-medium text-gray-900">
                <%= distributions .filter(d => d.jenis_zakat === 'beras' &&
                d.status !== 'batal') .reduce((sum, d) => sum +
                parseFloat(d.jumlah), 0) .toLocaleString('id-ID') %> kg
              </span>
            </div>
            <div class="flex justify-between detail-stat-item">
              <span class="text-sm text-gray-500">Uang Diterima</span>
              <span class="text-sm font-medium text-gray-900">
                Rp <%= distributions .filter(d => d.jenis_zakat === 'uang' &&
                d.status !== 'batal') .reduce((sum, d) => sum +
                parseFloat(d.jumlah), 0) .toLocaleString('id-ID') %>
              </span>
            </div>
            <div class="flex justify-between detail-stat-item">
              <span class="text-sm text-gray-500">Status Terakhir</span>
              <span class="text-sm font-medium text-gray-900">
                <% if (distributions.length > 0) { %> <%=
                distributions[0].status.charAt(0).toUpperCase() +
                distributions[0].status.slice(1) %> <% } else { %> Belum ada
                distribusi <% } %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .mustahik-detail-page {
    width: 100%;
    max-width: 100%;
    padding-top: 0.75rem;
    padding-bottom: 1.5rem;
    padding-left: 0.1rem;
    padding-right: 0.1rem;
    position: relative;
  }

  .mustahik-detail-page::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 8% 8%, rgba(16, 185, 129, 0.08), transparent 33%),
      radial-gradient(circle at 92% 18%, rgba(59, 130, 246, 0.08), transparent 32%);
    pointer-events: none;
    z-index: 0;
  }

  .mustahik-detail-page > * {
    position: relative;
    z-index: 1;
  }

  .mustahik-detail-page .detail-hero {
    position: relative;
    margin-bottom: 1.25rem;
    padding: 1.25rem 1.35rem;
    border-radius: 1rem;
    background:
      radial-gradient(circle at 85% 20%, rgba(255, 255, 255, 0.26), transparent 34%),
      linear-gradient(130deg, #0f9f2f 0%, #16a34a 45%, #0d9488 100%);
    box-shadow: 0 14px 34px rgba(22, 163, 74, 0.24);
    overflow: hidden;
  }

  .mustahik-detail-page .detail-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.24);
    pointer-events: none;
  }

  .mustahik-detail-page .detail-hero h1,
  .mustahik-detail-page .detail-hero p,
  .mustahik-detail-page .detail-hero a,
  .mustahik-detail-page .detail-hero i {
    color: #ffffff !important;
  }

  .mustahik-detail-page .detail-hero a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: 0.2s ease;
  }

  .mustahik-detail-page .detail-hero a:hover {
    transform: translateX(-2px);
    background: rgba(255, 255, 255, 0.24);
  }

  .mustahik-detail-page .detail-layout {
    gap: 1.25rem;
  }

  .mustahik-detail-page .detail-card {
    border: 1px solid #e7edf6;
    border-radius: 1rem;
    box-shadow: 0 10px 26px rgba(15, 23, 42, 0.07);
    overflow: hidden;
    transition: transform 0.26s ease, box-shadow 0.26s ease, border-color 0.26s ease;
    animation: mustahikFadeUp 0.45s ease both;
  }

  .mustahik-detail-page .detail-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.12);
    border-color: #d9e3ef;
  }

  .mustahik-detail-page .detail-card > .px-6.py-4.border-b.border-gray-200 {
    background: linear-gradient(180deg, #f9fbff 0%, #f3f7fb 100%);
    border-bottom-color: #e5edf5 !important;
  }

  .mustahik-detail-page .detail-main .detail-card + .detail-card {
    margin-top: 0;
  }

  .mustahik-detail-page .detail-card-primary .h-20.w-20 > div {
    box-shadow: 0 8px 20px rgba(139, 92, 246, 0.26);
    border: 2px solid rgba(255, 255, 255, 0.75);
  }

  .mustahik-detail-page .detail-card-primary .inline-flex.items-center.px-3.py-1.rounded-full {
    border: 1px solid rgba(15, 23, 42, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .mustahik-detail-page .detail-table-wrap {
    width: 100%;
    -webkit-overflow-scrolling: touch;
    border: 1px solid #e2e8f0;
    border-radius: 0.9rem;
    padding: 0.55rem;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .mustahik-detail-page .detail-table thead tr {
    background: transparent;
  }

  .mustahik-detail-page .detail-table {
    width: 100%;
    min-width: 640px;
    border-collapse: separate;
    border-spacing: 0 0.5rem;
  }

  .mustahik-detail-page .detail-table thead th {
    border: 0;
    padding: 0 0.85rem 0.6rem !important;
    font-size: 0.66rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.62px !important;
    color: #64748b !important;
    text-transform: uppercase;
  }

  .mustahik-detail-page .detail-table tbody td {
    background: #ffffff;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
    box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
    padding-top: 0.82rem !important;
    padding-bottom: 0.82rem !important;
    font-size: 0.86rem !important;
    color: #0f172a;
    transition: background 0.24s ease, border-color 0.24s ease;
  }

  .mustahik-detail-page .detail-table tbody td:first-child {
    border-left: 1px solid #e2e8f0;
    border-top-left-radius: 0.65rem;
    border-bottom-left-radius: 0.65rem;
  }

  .mustahik-detail-page .detail-table tbody td:last-child {
    border-right: 1px solid #e2e8f0;
    border-top-right-radius: 0.65rem;
    border-bottom-right-radius: 0.65rem;
  }

  .mustahik-detail-page .detail-table tbody tr {
    transition: transform 0.25s ease;
  }

  .mustahik-detail-page .detail-table tbody tr:hover {
    transform: translateY(-2px);
  }

  .mustahik-detail-page .detail-table tbody tr:hover td {
    background: #f0fdf4;
    border-color: #bbf7d0;
  }

  .mustahik-detail-page .detail-table td,
  .mustahik-detail-page .detail-table th {
    vertical-align: top;
  }

  .mustahik-detail-page .detail-table tbody td span.inline-flex {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 999px;
    letter-spacing: 0.2px;
    font-weight: 700;
  }

  html.dark-mode .mustahik-detail-page .detail-table-wrap {
    border-color: #1f2937;
    background: linear-gradient(180deg, #0f172a 0%, #020617 100%);
  }

  html.dark-mode .mustahik-detail-page .detail-table thead th {
    color: #94a3b8 !important;
  }

  html.dark-mode .mustahik-detail-page .detail-table tbody td {
    background: #0f172a;
    border-color: #1f2937;
    color: #e2e8f0;
    box-shadow: none;
  }

  html.dark-mode .mustahik-detail-page .detail-table tbody tr:hover td {
    background: #0b2a1b;
    border-color: #14532d;
  }

  html.dark-mode .mustahik-detail-page .detail-table tbody td span.inline-flex {
    border-color: rgba(148, 163, 184, 0.25);
  }

  .mustahik-detail-page .detail-side .detail-card {
    position: sticky;
    top: 86px;
  }

  .mustahik-detail-page .detail-side .detail-card + .detail-card {
    position: static;
  }

  .mustahik-detail-page .detail-card-actions .btn-primary,
  .mustahik-detail-page .detail-card-actions .btn-secondary,
  .mustahik-detail-page .detail-card-actions .btn-danger {
    border-radius: 0.75rem;
    font-weight: 700;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .mustahik-detail-page .detail-card-actions .btn-primary {
    background: linear-gradient(135deg, #16a34a 0%, #0d9488 100%);
    color: #ffffff !important;
    border: none;
    box-shadow: 0 8px 18px rgba(16, 185, 129, 0.25);
  }

  .mustahik-detail-page .detail-card-actions .btn-secondary {
    border: 1px solid #d8e3ee;
    background: #f8fafc;
    color: #0f172a !important;
  }

  .mustahik-detail-page .detail-card-actions .btn-danger {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: #ffffff !important;
    border: none;
    box-shadow: 0 8px 18px rgba(239, 68, 68, 0.22);
  }

  .mustahik-detail-page .detail-card-actions .btn-primary:hover,
  .mustahik-detail-page .detail-card-actions .btn-secondary:hover,
  .mustahik-detail-page .detail-card-actions .btn-danger:hover {
    transform: translateY(-2px);
  }

  .mustahik-detail-page .detail-card-stats .space-y-4 > div {
    padding-bottom: 0.55rem;
    border-bottom: 1px dashed #e2e8f0;
  }

  .mustahik-detail-page .detail-card-stats .space-y-4 > div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .mustahik-detail-page .detail-card-stats .text-sm.font-medium.text-gray-900 {
    font-weight: 700;
    color: #0f172a;
  }

  /* Visual Refresh */
  .mustahik-detail-page .detail-hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .mustahik-detail-page .detail-hero-title {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .mustahik-detail-page .detail-hero-title > div {
    min-width: 0;
  }

  .mustahik-detail-page .detail-hero-title h1 {
    letter-spacing: 0.2px;
    line-height: 1.2;
    text-shadow: 0 3px 16px rgba(15, 23, 42, 0.24);
  }

  .mustahik-detail-page .detail-hero-title p {
    font-size: 0.92rem;
    opacity: 0.95;
  }

  .mustahik-detail-page .detail-hero-kpis {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .mustahik-detail-page .detail-hero-kpi {
    min-width: 145px;
    padding: 0.52rem 0.72rem;
    border-radius: 0.72rem;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.28);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(4px);
  }

  .mustahik-detail-page .detail-hero-kpi span {
    display: block;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.45px;
    text-transform: uppercase;
    opacity: 0.92;
    color: #dcfce7;
  }

  .mustahik-detail-page .detail-hero-kpi strong {
    display: block;
    margin-top: 0.12rem;
    font-size: 0.92rem;
    font-weight: 800;
    color: #ffffff;
    text-transform: capitalize;
    overflow-wrap: anywhere;
  }

