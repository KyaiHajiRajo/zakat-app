<script>
  // Handle delete form submission with SweetAlert2
  document
    .getElementById("deleteForm")
    .addEventListener("submit", function (e) {
      e.preventDefault();

      showDeleteConfirm(
        "<%= mustahik.nama %>",
        "Apakah Anda yakin ingin menghapus data mustahik <%= mustahik.nama %>? Tindakan ini tidak dapat dibatalkan."
      ).then((result) => {
        if (result.isConfirmed) {
          this.submit();
        }
      });
    });
</script>

