<%- include('../layouts/header', { title: 'Data RW - Zakat Fitrah App', bodyClass: 'bg-gray-50 min-h-screen', currentPage: 'rt' }) %>

<%
  const rwData = Array.isArray(rwList) ? rwList : [];
  const totalRw = rwData.length;
  const totalRt = rwData.reduce((sum, item) => sum + Number(item.total_rt || 0), 0);
  const totalMuzakki = rwData.reduce((sum, item) => sum + Number(item.total_muzakki || 0), 0);
%>

<style>
  .rw-index-page {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.44rem 0.16rem 1rem;
  }

  .rw-index-shell {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.84rem;
  }

  .rw-index-bg {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    border-radius: 9999px;
    filter: blur(12px);
  }

  .rw-index-bg-a {
    width: 230px;
    height: 230px;
    top: 20px;
    right: -80px;
    background: radial-gradient(circle, rgba(34, 197, 94, 0.22) 0%, rgba(34, 197, 94, 0) 70%);
  }

  .rw-index-bg-b {
    width: 180px;
    height: 180px;
    bottom: 70px;
    left: -68px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.16) 0%, rgba(59, 130, 246, 0) 72%);
  }

  .rw-index-hero {
    background: linear-gradient(125deg, #0f766e 0%, #16a34a 56%, #22c55e 100%);
    border-radius: 18px;
    padding: 0.78rem 0.78rem;
    color: #fff;
    box-shadow: 0 16px 34px rgba(22, 163, 74, 0.26);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    position: relative;
    overflow: hidden;
  }

  .rw-index-hero::after {
    content: "";
    position: absolute;
    width: 260px;
    height: 260px;
    top: -160px;
    right: -70px;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0) 70%);
  }

  .rw-index-hero-main {
    position: relative;
    z-index: 2;
    min-width: 0;
  }

  .rw-index-title {
    margin: 0;
    font-size: 1.34rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.1px;
  }

  .rw-index-subtitle {
    margin: 0.22rem 0 0;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.5;
    max-width: 620px;
  }

  .rw-index-add-btn {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.56rem 0.88rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.92);
    color: #065f46;
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 20px rgba(6, 95, 70, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .rw-index-add-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(6, 95, 70, 0.24);
  }

  .rw-index-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .rw-index-stat {
    border-radius: 14px;
    border: 1px solid #d1d5db;
    background: #fff;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
    padding: 0.74rem 0.82rem;
    display: flex;
    align-items: center;
    gap: 0.64rem;
  }

  .rw-index-stat-icon {
    width: 35px;
    height: 35px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.84rem;
    flex-shrink: 0;
  }

  .rw-index-stat-icon-rw {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  }

  .rw-index-stat-icon-rt {
    background: linear-gradient(135deg, #059669 0%, #10b981 100%);
  }

  .rw-index-stat-icon-muzakki {
    background: linear-gradient(135deg, #ea580c 0%, #f97316 100%);
  }

  .rw-index-stat-label {
    margin: 0;
    font-size: 0.73rem;
    color: #64748b;
    font-weight: 600;
  }

  .rw-index-stat-value {
    margin: 0.12rem 0 0;
    font-size: 1.12rem;
    color: #0f172a;
    font-weight: 700;
    line-height: 1.2;
  }

  .rw-index-card {
    border-radius: 16px;
    border: 1px solid #d1d5db;
    background: #fff;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }

  .rw-index-card-head {
    padding: 0.72rem 0.76rem;
    border-bottom: 1px solid #e5e7eb;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
  }

  .rw-index-card-title {
    margin: 0;
    font-size: 0.96rem;
    color: #0f172a;
    font-weight: 700;
  }

  .rw-index-card-subtitle {
    margin: 0.2rem 0 0;
    font-size: 0.76rem;
    color: #64748b;
  }

  .rw-index-count-chip {
    border-radius: 9999px;
    padding: 0.36rem 0.62rem;
    background: #dcfce7;
    color: #166534;
    font-size: 0.72rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .rw-index-table-wrap {
    padding: 0.42rem;
  }

  .rw-index-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 840px;
  }

  .rw-index-table thead th {
    background: #f8fafc;
    border-bottom: 1px solid #e5e7eb;
    padding: 0.62rem 0.6rem;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.34px;
    color: #64748b;
    text-align: left;
    font-weight: 700;
  }

  .rw-index-table tbody td {
    border-bottom: 1px solid #eef2f7;
    padding: 0.66rem 0.6rem;
    vertical-align: top;
    font-size: 0.8rem;
    color: #0f172a;
  }

  .rw-index-table tbody tr:hover {
    background: #f8fafc;
  }

  .rw-index-rw-cell {
    display: flex;
    align-items: center;
    gap: 0.52rem;
  }

  .rw-index-rw-icon {
    width: 33px;
    height: 33px;
    border-radius: 9px;
    background: linear-gradient(135deg, #d1fae5 0%, #bbf7d0 100%);
    color: #047857;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
    flex-shrink: 0;
  }

  .rw-index-rw-name {
    margin: 0;
    font-size: 0.83rem;
    font-weight: 700;
    color: #0f172a;
  }

  .rw-index-rw-id {
    margin: 0.1rem 0 0;
    font-size: 0.7rem;
    color: #64748b;
  }

  .rw-index-badges {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    flex-wrap: wrap;
  }

  .rw-index-badge {
    border-radius: 9999px;
    padding: 0.28rem 0.52rem;
    font-size: 0.68rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 0.26rem;
    white-space: nowrap;
  }

  .rw-index-badge-rt {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .rw-index-badge-muzakki {
    background: #dcfce7;
    color: #166534;
  }

  .rw-index-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .rw-index-action {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    background: #f8fafc;
    color: #334155;
  }

  .rw-index-action:hover {
    transform: translateY(-1px);
  }

  .rw-index-action-view {
    color: #1d4ed8;
    background: #eff6ff;
  }

  .rw-index-action-edit {
    color: #7c3aed;
    background: #f3e8ff;
  }

  .rw-index-action-delete {
    color: #b91c1c;
    background: #fee2e2;
    border: 0;
  }

  .rw-index-mobile-list {
    display: none;
    padding: 0.42rem;
    gap: 0.56rem;
  }

  .rw-index-mobile-card {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.66rem;
    background: #fff;
    display: grid;
    gap: 0.46rem;
  }

  .rw-index-mobile-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .rw-index-mobile-name {
    margin: 0;
    font-size: 0.86rem;
    font-weight: 700;
    color: #0f172a;
  }

  .rw-index-mobile-sub {
    margin: 0.12rem 0 0;
    font-size: 0.72rem;
    color: #64748b;
  }

  .rw-index-mobile-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .rw-index-mobile-label {
    margin: 0;
    font-size: 0.64rem;
    text-transform: uppercase;
    color: #64748b;
    letter-spacing: 0.28px;
    font-weight: 700;
  }

  .rw-index-mobile-value {
    margin: 0.15rem 0 0;
    font-size: 0.77rem;
    color: #0f172a;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .rw-index-empty {
    padding: 2.2rem 1rem;
    text-align: center;
  }

  .rw-index-empty i {
    font-size: 2.3rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }

  .rw-index-empty h3 {
    margin: 0;
    font-size: 1rem;
    color: #0f172a;
    font-weight: 700;
  }

  .rw-index-empty p {
    margin: 0.34rem auto 0;
    font-size: 0.8rem;
    color: #64748b;
    max-width: 460px;
  }

  .rw-index-empty a {
    margin-top: 0.76rem;
  }

  .rw-index-reveal {
    opacity: 0;
    transform: translateY(10px);
    animation: rwIndexReveal 0.5s ease forwards;
    animation-delay: var(--rw-delay, 0ms);
  }

  @keyframes rwIndexReveal {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .rw-index-table-wrap {
      display: none;
    }

    .rw-index-mobile-list {
      display: grid;
    }
  }

  @media (max-width: 760px) {
    .rw-index-page {
      padding: 0.38rem 0.12rem 0.82rem;
    }

    .rw-index-hero {
      padding: 0.66rem 0.64rem;
      border-radius: 15px;
      flex-direction: column;
      align-items: flex-start;
    }

    .rw-index-stats {
      grid-template-columns: 1fr;
    }

    .rw-index-card-head {
      padding: 0.64rem;
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 460px) {
    .rw-index-page {
      padding: 0.32rem 0.1rem 0.74rem;
    }

    .rw-index-title {
      font-size: 1.08rem;
    }

    .rw-index-subtitle {
      font-size: 0.74rem;
    }

    .rw-index-add-btn {
      width: 100%;
      justify-content: center;
    }

    .rw-index-mobile-row {
      grid-template-columns: 1fr;
    }
  }

  html.dark-mode .rw-index-hero {
    box-shadow: 0 12px 28px rgba(2, 6, 23, 0.45);
  }

  html.dark-mode .rw-index-add-btn {
    background: rgba(2, 6, 23, 0.9);
    color: #86efac;
  }

  html.dark-mode .rw-index-stat,
  html.dark-mode .rw-index-card,
  html.dark-mode .rw-index-mobile-card {
    background: #0f172a;
    border-color: #1f2937;
    box-shadow: none;
  }

  html.dark-mode .rw-index-card-head {
    background: #111827;
    border-bottom-color: #1f2937;
  }

  html.dark-mode .rw-index-stat-label,
  html.dark-mode .rw-index-card-subtitle,
  html.dark-mode .rw-index-rw-id,
  html.dark-mode .rw-index-mobile-sub,
  html.dark-mode .rw-index-mobile-label,
  html.dark-mode .rw-index-empty p {
    color: #94a3b8;
  }

  html.dark-mode .rw-index-stat-value,
  html.dark-mode .rw-index-card-title,
  html.dark-mode .rw-index-rw-name,
  html.dark-mode .rw-index-mobile-name,
  html.dark-mode .rw-index-mobile-value,
  html.dark-mode .rw-index-empty h3,
  html.dark-mode .rw-index-table tbody td {
    color: #f8fafc;
  }

  html.dark-mode .rw-index-table thead th {
    background: #111827;
    border-bottom-color: #1f2937;
    color: #94a3b8;
  }

  html.dark-mode .rw-index-table tbody td {
    border-bottom-color: #1f2937;
  }

  html.dark-mode .rw-index-table tbody tr:hover {
    background: #111827;
  }

  html.dark-mode .rw-index-action {
    background: #111827;
    border-color: #1f2937;
  }

  html.dark-mode .rw-index-action-view {
    color: #93c5fd;
  }

  html.dark-mode .rw-index-action-edit {
    color: #d8b4fe;
  }

  html.dark-mode .rw-index-action-delete {
    color: #fca5a5;
  }
</style>

<section class="rw-index-page">
  <div class="rw-index-bg rw-index-bg-a"></div>
  <div class="rw-index-bg rw-index-bg-b"></div>

  <div class="rw-index-shell">
    <header class="rw-index-hero rw-index-reveal" style="--rw-delay: 0ms;">
      <div class="rw-index-hero-main">
        <h1 class="rw-index-title"><i class="fas fa-building mr-1"></i>Data RW</h1>
        <p class="rw-index-subtitle">
          Kelola wilayah Rukun Warga, pantau statistik RT dan muzakki, lalu lakukan pemeliharaan data dengan cepat.
        </p>
      </div>
      <a href="/rw/create" class="rw-index-add-btn">
        <i class="fas fa-plus"></i>Tambah RW
      </a>
    </header>

    <section class="rw-index-stats rw-index-reveal" style="--rw-delay: 70ms;">
      <article class="rw-index-stat">
        <div class="rw-index-stat-icon rw-index-stat-icon-rw">
          <i class="fas fa-building"></i>
        </div>
        <div>
          <p class="rw-index-stat-label">Total RW</p>
          <p class="rw-index-stat-value"><%= totalRw %></p>
        </div>
      </article>
      <article class="rw-index-stat">
        <div class="rw-index-stat-icon rw-index-stat-icon-rt">
          <i class="fas fa-home"></i>
        </div>
        <div>
          <p class="rw-index-stat-label">Total RT</p>
          <p class="rw-index-stat-value"><%= totalRt %></p>
        </div>
      </article>
      <article class="rw-index-stat">
        <div class="rw-index-stat-icon rw-index-stat-icon-muzakki">
          <i class="fas fa-users"></i>
        </div>
        <div>
          <p class="rw-index-stat-label">Total Muzakki</p>
          <p class="rw-index-stat-value"><%= totalMuzakki %></p>
        </div>
      </article>
    </section>

    <section class="rw-index-card rw-index-reveal" style="--rw-delay: 120ms;">
      <div class="rw-index-card-head">
        <div>
          <h2 class="rw-index-card-title">Daftar RW</h2>
          <p class="rw-index-card-subtitle">Klik ikon aksi untuk melihat detail, mengubah, atau menghapus data RW.</p>
        </div>
        <span class="rw-index-count-chip"><%= totalRw %> RW</span>
      </div>

      <% if (rwData.length > 0) { %>
      <div class="rw-index-table-wrap">
        <table class="rw-index-table">
          <thead>
            <tr>
              <th>RW</th>
              <th>Ketua RW</th>
              <th>Keterangan</th>
              <th>Statistik</th>
              <th style="text-align: right;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% rwData.forEach(function(rw) { %>
            <tr>
              <td>
                <div class="rw-index-rw-cell">
                  <div class="rw-index-rw-icon">
                    <i class="fas fa-building"></i>
                  </div>
                  <div>
                    <p class="rw-index-rw-name"><%= rw.nomor_rw %></p>
                    <p class="rw-index-rw-id">ID: <%= rw.id %></p>
                  </div>
                </div>
              </td>
              <td><%= rw.ketua_rw %></td>
              <td><%= rw.keterangan || '-' %></td>
              <td>
                <div class="rw-index-badges">
                  <span class="rw-index-badge rw-index-badge-rt"><i class="fas fa-home"></i><%= rw.total_rt || 0 %> RT</span>
                  <span class="rw-index-badge rw-index-badge-muzakki"><i class="fas fa-users"></i><%= rw.total_muzakki || 0 %> Muzakki</span>
                </div>
              </td>
              <td style="text-align: right;">
                <div class="rw-index-actions">
                  <a href="/rw/<%= rw.id %>/detail" class="rw-index-action rw-index-action-view" title="Detail RW">
                    <i class="fas fa-eye"></i>
                  </a>
                  <a href="/rw/<%= rw.id %>/edit" class="rw-index-action rw-index-action-edit" title="Edit RW">
                    <i class="fas fa-pen"></i>
                  </a>
                  <form method="POST" action="/rw/<%= rw.id %>/delete" class="inline delete-form" data-rw-nomor="<%= rw.nomor_rw %>">
                    <button type="button" class="rw-index-action rw-index-action-delete delete-btn" title="Hapus RW">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div class="rw-index-mobile-list">
        <% rwData.forEach(function(rw) { %>
        <article class="rw-index-mobile-card">
          <div class="rw-index-mobile-top">
            <div>
              <h3 class="rw-index-mobile-name"><%= rw.nomor_rw %></h3>
              <p class="rw-index-mobile-sub">Ketua: <%= rw.ketua_rw %></p>
            </div>
            <div class="rw-index-actions">
              <a href="/rw/<%= rw.id %>/detail" class="rw-index-action rw-index-action-view" title="Detail RW">
                <i class="fas fa-eye"></i>
              </a>
              <a href="/rw/<%= rw.id %>/edit" class="rw-index-action rw-index-action-edit" title="Edit RW">
                <i class="fas fa-pen"></i>
              </a>
              <form method="POST" action="/rw/<%= rw.id %>/delete" class="inline delete-form" data-rw-nomor="<%= rw.nomor_rw %>">
                <button type="button" class="rw-index-action rw-index-action-delete delete-btn" title="Hapus RW">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
            </div>
          </div>

          <div class="rw-index-mobile-row">
            <div>
              <p class="rw-index-mobile-label">Keterangan</p>
              <p class="rw-index-mobile-value"><%= rw.keterangan || '-' %></p>
            </div>
            <div>
              <p class="rw-index-mobile-label">Statistik</p>
              <p class="rw-index-mobile-value"><%= rw.total_rt || 0 %> RT, <%= rw.total_muzakki || 0 %> Muzakki</p>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
      <% } else { %>
      <div class="rw-index-empty">
        <i class="fas fa-building"></i>
        <h3>Belum Ada Data RW</h3>
        <p>Mulai dengan menambahkan data RW pertama agar struktur wilayah dan data RT bisa dikelola.</p>
        <a href="/rw/create" class="rw-index-add-btn">
          <i class="fas fa-plus"></i>Tambah RW Pertama
        </a>
      </div>
      <% } %>
    </section>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".delete-btn").forEach((button) => {
      button.addEventListener("click", function () {
        const form = this.closest(".delete-form");
        const rwNomor = form.getAttribute("data-rw-nomor");

        Swal.fire({
          title: "Konfirmasi Hapus",
          text: "Yakin ingin menghapus RW " + rwNomor + "? Data ini tidak dapat dikembalikan.",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#dc2626",
          cancelButtonColor: "#64748b",
          confirmButtonText: "Ya, Hapus",
          cancelButtonText: "Batal",
        }).then((result) => {
          if (result.isConfirmed) {
            form.submit();
          }
        });
      });
    });
  });
</script>

<% if (error) { %>
<script>
  Swal.fire({
    icon: "error",
    title: "Error",
    text: <%- JSON.stringify(error) %>,
    confirmButtonText: "OK",
  });
</script>
<% } %>

<% if (success) { %>
<script>
  Swal.fire({
    icon: "success",
    title: "Berhasil",
    text: <%- JSON.stringify(success) %>,
    confirmButtonText: "OK",
  });
</script>
<% } %>

<%- include('../layouts/footer') %>
