<%- include('../layouts/header', { title: 'Tambah RW - Zakat Fitrah App', bodyClass: 'bg-gray-50 min-h-screen', currentPage: 'rt' }) %>

<style>
  .rw-create-page {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0.42rem 0.14rem 0.92rem;
  }

  .rw-create-shell {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.82rem;
  }

  .rw-create-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(10px);
    pointer-events: none;
    z-index: 1;
  }

  .rw-create-orb-a {
    width: 210px;
    height: 210px;
    top: 18px;
    right: -68px;
    background: radial-gradient(circle, rgba(34, 197, 94, 0.2) 0%, rgba(34, 197, 94, 0) 72%);
  }

  .rw-create-orb-b {
    width: 170px;
    height: 170px;
    bottom: 70px;
    left: -52px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.16) 0%, rgba(59, 130, 246, 0) 72%);
  }

  .rw-create-hero {
    background: linear-gradient(125deg, #0f766e 0%, #16a34a 58%, #22c55e 100%);
    border-radius: 17px;
    color: #fff;
    padding: 0.74rem 0.74rem;
    box-shadow: 0 16px 34px rgba(22, 163, 74, 0.24);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.74rem;
    position: relative;
    overflow: hidden;
  }

  .rw-create-hero::after {
    content: "";
    position: absolute;
    width: 250px;
    height: 250px;
    border-radius: 9999px;
    top: -154px;
    right: -74px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0) 70%);
  }

  .rw-create-hero-main {
    position: relative;
    z-index: 2;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .rw-create-back {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .rw-create-back:hover {
    background: rgba(255, 255, 255, 0.22);
    transform: translateY(-1px);
  }

  .rw-create-title {
    margin: 0;
    font-size: 1.22rem;
    line-height: 1.2;
    font-weight: 700;
  }

  .rw-create-subtitle {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.92);
  }

  .rw-create-chip {
    position: relative;
    z-index: 2;
    border-radius: 9999px;
    padding: 0.5rem 0.78rem;
    background: rgba(255, 255, 255, 0.9);
    color: #065f46;
    font-size: 0.73rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 0.36rem;
    white-space: nowrap;
  }

  .rw-create-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.84rem;
    align-items: start;
  }

  .rw-create-card {
    border-radius: 16px;
    background: #fff;
    border: 1px solid #d1d5db;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }

  .rw-create-card-head {
    padding: 0.74rem 0.76rem;
    border-bottom: 1px solid #e5e7eb;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .rw-create-card-title {
    margin: 0;
    font-size: 0.98rem;
    color: #0f172a;
    font-weight: 700;
  }

  .rw-create-card-desc {
    margin: 0.2rem 0 0;
    font-size: 0.76rem;
    color: #64748b;
    line-height: 1.46;
  }

  .rw-create-form {
    padding: 0.74rem 0.76rem;
    display: grid;
    gap: 0.72rem;
  }

  .rw-create-field {
    border: 1px solid #e5e7eb;
    background: #f8fafc;
    border-radius: 12px;
    padding: 0.56rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .rw-create-field:focus-within {
    border-color: rgba(22, 163, 74, 0.4);
    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
  }

  .rw-create-label {
    margin: 0 0 0.36rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: #1f2937;
  }

  .rw-create-required {
    color: #dc2626;
  }

  .rw-create-input-wrap {
    position: relative;
  }

  .rw-create-input-wrap i {
    position: absolute;
    left: 0.72rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.82rem;
    pointer-events: none;
  }

  .rw-create-input-wrap-textarea i {
    top: 0.86rem;
    transform: none;
  }

  .rw-create-control {
    width: 100%;
    border: 1px solid #d1d5db;
    background: #fff;
    border-radius: 9px;
    color: #0f172a;
    font-size: 0.84rem;
    line-height: 1.46;
    padding: 0.56rem 0.62rem 0.56rem 2.02rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .rw-create-control:focus {
    outline: none;
    border-color: #16a34a;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.14);
  }

  .rw-create-help {
    margin: 0.34rem 0 0;
    font-size: 0.71rem;
    color: #64748b;
    line-height: 1.44;
  }

  .rw-create-actions {
    margin-top: 0.14rem;
    border-top: 1px solid #e5e7eb;
    padding-top: 0.76rem;
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .rw-create-btn {
    border: 0;
    border-radius: 9px;
    padding: 0.56rem 0.84rem;
    font-size: 0.78rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .rw-create-btn:hover {
    transform: translateY(-1px);
  }

  .rw-create-btn-secondary {
    background: #e5e7eb;
    color: #1f2937;
  }

  .rw-create-btn-secondary:hover {
    background: #d1d5db;
  }

  .rw-create-btn-primary {
    background: linear-gradient(130deg, #15803d 0%, #16a34a 100%);
    color: #fff;
    box-shadow: 0 10px 20px rgba(22, 163, 74, 0.24);
  }

  .rw-create-btn-primary:hover {
    box-shadow: 0 12px 24px rgba(22, 163, 74, 0.3);
  }

  .rw-create-side {
    border-radius: 16px;
    background: #fff;
    border: 1px solid #d1d5db;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
    padding: 0.72rem;
  }

  .rw-create-side-title {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #0f172a;
    font-weight: 700;
  }

  .rw-create-side-title i {
    width: 27px;
    height: 27px;
    border-radius: 8px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    color: #1d4ed8;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.74rem;
  }

  .rw-create-side-list {
    margin: 0.72rem 0 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.44rem;
    color: #334155;
    font-size: 0.77rem;
    line-height: 1.48;
  }

  .rw-create-reveal {
    opacity: 0;
    transform: translateY(10px);
    animation: rwCreateReveal 0.52s ease forwards;
    animation-delay: var(--rw-create-delay, 0ms);
  }

  @keyframes rwCreateReveal {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 1024px) {
    .rw-create-grid {
      grid-template-columns: minmax(0, 1fr) 330px;
    }
  }

  @media (max-width: 760px) {
    .rw-create-page {
      padding: 0.34rem 0.1rem 0.76rem;
    }

    .rw-create-hero {
      border-radius: 14px;
      padding: 0.62rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .rw-create-chip {
      white-space: normal;
    }
  }

  @media (max-width: 460px) {
    .rw-create-page {
      padding: 0.28rem 0.08rem 0.64rem;
    }

    .rw-create-title {
      font-size: 1.05rem;
    }

    .rw-create-subtitle {
      font-size: 0.72rem;
    }

    .rw-create-card-head,
    .rw-create-form,
    .rw-create-side {
      padding: 0.6rem;
    }

    .rw-create-actions {
      justify-content: stretch;
    }

    .rw-create-btn {
      width: 100%;
    }
  }

  html.dark-mode .rw-create-hero {
    box-shadow: 0 12px 28px rgba(2, 6, 23, 0.45);
  }

  html.dark-mode .rw-create-chip {
    background: rgba(2, 6, 23, 0.88);
    color: #86efac;
  }

  html.dark-mode .rw-create-card,
  html.dark-mode .rw-create-side {
    background: #0f172a;
    border-color: #1f2937;
    box-shadow: none;
  }

  html.dark-mode .rw-create-card-head {
    background: #111827;
    border-bottom-color: #1f2937;
  }

  html.dark-mode .rw-create-card-title,
  html.dark-mode .rw-create-label,
  html.dark-mode .rw-create-side-title {
    color: #f8fafc;
  }

  html.dark-mode .rw-create-card-desc,
  html.dark-mode .rw-create-help,
  html.dark-mode .rw-create-side-list {
    color: #94a3b8;
  }

  html.dark-mode .rw-create-field {
    background: #111827;
    border-color: #1f2937;
  }

  html.dark-mode .rw-create-control {
    background: #0b1220;
    border-color: #334155;
    color: #e2e8f0;
  }

  html.dark-mode .rw-create-control::placeholder {
    color: #64748b;
  }

  html.dark-mode .rw-create-btn-secondary {
    background: #1f2937;
    color: #e2e8f0;
  }

  html.dark-mode .rw-create-btn-secondary:hover {
    background: #374151;
  }
</style>

<section class="rw-create-page">
  <div class="rw-create-orb rw-create-orb-a"></div>
  <div class="rw-create-orb rw-create-orb-b"></div>

  <div class="rw-create-shell">
    <header class="rw-create-hero rw-create-reveal" style="--rw-create-delay: 0ms;">
      <div class="rw-create-hero-main">
        <a href="/rw" class="rw-create-back" aria-label="Kembali ke daftar RW">
          <i class="fas fa-arrow-left"></i>
        </a>
        <div>
          <h1 class="rw-create-title"><i class="fas fa-plus mr-1"></i>Tambah RW</h1>
          <p class="rw-create-subtitle">Tambahkan data RW baru agar struktur wilayah lebih rapi dan terdokumentasi.</p>
        </div>
      </div>
      <span class="rw-create-chip"><i class="fas fa-circle-info"></i>Form Pendaftaran RW</span>
    </header>

    <div class="rw-create-grid">
      <article class="rw-create-card rw-create-reveal" style="--rw-create-delay: 90ms;">
        <div class="rw-create-card-head">
          <h2 class="rw-create-card-title">Informasi RW</h2>
          <p class="rw-create-card-desc">Isi nomor RW, nama ketua RW, dan keterangan jika diperlukan.</p>
        </div>

        <form method="POST" action="/rw/create" class="rw-create-form" id="rw-form">
          <div class="rw-create-field">
            <label for="nomor_rw" class="rw-create-label">Nomor RW <span class="rw-create-required">*</span></label>
            <div class="rw-create-input-wrap">
              <i class="fas fa-building"></i>
              <input type="text" id="nomor_rw" name="nomor_rw" required placeholder="Contoh: RW 01, RW 02, RW 11" class="rw-create-control" />
            </div>
            <p class="rw-create-help">Format yang disarankan: RW 01, RW 02, RW 11.</p>
          </div>

          <div class="rw-create-field">
            <label for="ketua_rw" class="rw-create-label">Nama Ketua RW <span class="rw-create-required">*</span></label>
            <div class="rw-create-input-wrap">
              <i class="fas fa-user"></i>
              <input type="text" id="ketua_rw" name="ketua_rw" required placeholder="Nama lengkap ketua RW" class="rw-create-control" />
            </div>
            <p class="rw-create-help">Gunakan nama resmi agar validasi data lebih mudah.</p>
          </div>

          <div class="rw-create-field">
            <label for="keterangan" class="rw-create-label">Keterangan</label>
            <div class="rw-create-input-wrap rw-create-input-wrap-textarea">
              <i class="fas fa-note-sticky"></i>
              <textarea id="keterangan" name="keterangan" rows="4" placeholder="Catatan tambahan atau keterangan RW (opsional)" class="rw-create-control"></textarea>
            </div>
            <p class="rw-create-help">Opsional, isi jika ada catatan penting terkait RW ini.</p>
          </div>

          <div class="rw-create-actions">
            <a href="/rw" class="rw-create-btn rw-create-btn-secondary">
              <i class="fas fa-xmark"></i>Batal
            </a>
            <button type="submit" class="rw-create-btn rw-create-btn-primary">
              <i class="fas fa-floppy-disk"></i>Simpan RW
            </button>
          </div>
        </form>
      </article>

      <aside class="rw-create-side rw-create-reveal" style="--rw-create-delay: 160ms;">
        <h3 class="rw-create-side-title">
          <i class="fas fa-list-check"></i>Panduan Pengisian
        </h3>
        <ul class="rw-create-side-list">
          <li>Nomor RW wajib unik dan belum terdaftar sebelumnya.</li>
          <li>Gunakan pola standar agar pencarian data lebih cepat.</li>
          <li>Nama ketua RW dipakai sebagai identitas utama wilayah.</li>
          <li>Keterangan boleh dikosongkan dan diubah kapan saja.</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<script>
  const rwForm = document.getElementById("rw-form");
  const nomorRwInput = document.getElementById("nomor_rw");
  const ketuaRwInput = document.getElementById("ketua_rw");

  rwForm.addEventListener("submit", function (e) {
    e.preventDefault();
    const nomorRw = nomorRwInput.value.trim();
    const ketuaRw = ketuaRwInput.value.trim();

    if (!nomorRw || !ketuaRw) {
      Swal.fire({
        icon: "error",
        title: "Error",
        text: "Nomor RW dan Nama Ketua RW harus diisi.",
        confirmButtonText: "OK",
      });
      return false;
    }

    Swal.fire({
      title: "Konfirmasi Simpan",
      text: "Apakah data RW yang dimasukkan sudah benar?",
      icon: "question",
      showCancelButton: true,
      confirmButtonColor: "#15803d",
      cancelButtonColor: "#64748b",
      confirmButtonText: "Ya, Simpan",
      cancelButtonText: "Batal",
    }).then((result) => {
      if (result.isConfirmed) {
        this.submit();
      }
    });
  });

  nomorRwInput.addEventListener("input", function (e) {
    let value = e.target.value.toUpperCase();

    if (/^\d+$/.test(value)) {
      const num = parseInt(value, 10);
      e.target.value = num < 10 ? "RW 0" + num : "RW " + num;
    }
  });
</script>

<% if (error) { %>
<script>
  Swal.fire({
    icon: "error",
    title: "Error",
    text: <%- JSON.stringify(error) %>,
    confirmButtonText: "OK",
  });
</script>
<% } %>

<% if (success) { %>
<script>
  Swal.fire({
    icon: "success",
    title: "Berhasil",
    text: <%- JSON.stringify(success) %>,
    confirmButtonText: "OK",
  });
</script>
<% } %>

<%- include('../layouts/footer') %>
