    border: 1px solid #bfdbfe;
    background: #eff6ff;
    color: #1d4ed8;
    font-weight: 700;
    box-shadow: none;
  }

  #infakModalOverlay .infak-add-row-btn:not(:disabled):hover {
    background: #dbeafe;
  }

  #infakModalOverlay .infak-form-footer {
    border-top: 1px solid #e2e8f0;
    padding-top: 14px;
    gap: 12px;
  }

  #infakModalOverlay .infak-form-hint {
    margin: 0;
    color: #64748b;
    font-size: 12px;
  }

  #infakModalOverlay .infak-form-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  #infakModalOverlay .infak-modal-cancel,
  #infakModalOverlay .infak-modal-submit {
    min-width: 132px;
    height: 42px;
    border-radius: 10px;
    padding: 0 16px;
    font-size: 13px;
    font-weight: 700;
    box-shadow: none;
  }

  #infakModalOverlay .infak-modal-cancel {
    border: 1px solid #cbd5e1;
    background: #ffffff;
    color: #334155;
  }

  #infakModalOverlay .infak-modal-cancel:hover {
    background: #f8fafc;
    transform: none;
  }

  #infakModalOverlay .infak-modal-submit {
    border: 1px solid #1d4ed8;
    background: #2563eb;
    color: #ffffff;
  }

  #infakModalOverlay .infak-modal-submit:hover {
    background: #1d4ed8;
    transform: none;
  }

  @media (max-width: 920px) {
    #infakModalOverlay .infak-row {
      grid-template-columns: 1fr 1fr;
    }

    #infakModalOverlay .infak-remove-row {
      width: 100%;
      height: 40px;
    }
  }

  @media (max-width: 640px) {
    #infakModalOverlay .infak-modal-card {
      border-radius: 16px;
    }

    #infakModalOverlay .infak-modal-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    #infakModalOverlay .infak-meta-text {
      text-align: left;
    }

    #infakModalOverlay .infak-row {
      grid-template-columns: 1fr;
      padding: 14px;
      gap: 12px;
    }

    #infakModalOverlay .infak-form-buttons {
      width: 100%;
      flex-direction: column;
    }

    #infakModalOverlay .infak-modal-cancel,
    #infakModalOverlay .infak-modal-submit {
      width: 100%;
    }
  }
</style>
