<%
  const optionMarkup = (availableMuzakki || [])
    .map((muzakki) => {
      const label = muzakki.nomor_rt
        ? `${muzakki.nama} - RT ${muzakki.nomor_rt}`
        : muzakki.nama;
      return `<option value="${muzakki.id}">${label}</option>`;
    })
    .join("");
  const hasOptions = Boolean(optionMarkup);
%>

<link
  href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"
  rel="stylesheet"
/>

<div id="infakModalOverlay" class="infak-modal-overlay hidden">
  <div class="infak-modal-card" role="dialog" aria-modal="true" aria-labelledby="infakModalTitle">
    <div class="infak-modal-header">
      <div>
        <p class="infak-modal-kicker">Input Infak</p>
        <h2 id="infakModalTitle" class="infak-modal-title">Tambah Sodakoh</h2>
        <p class="infak-modal-subtitle">
          Rekam infak secara manual untuk muzakki tanpa catatan sebelumnya.
        </p>
      </div>
      <button
        type="button"
        class="infak-modal-close"
        onclick="closeInfakModal()"
        aria-label="Tutup modal"
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <form id="infakModalForm" class="infak-modal-form" action="/infak/create" method="POST">
      <% if (!hasOptions) { %>
        <div class="infak-no-options-text">
          Semua muzakki sudah memiliki catatan infak. Tambahkan muzakki baru terlebih dahulu
          jika diperlukan.
        </div>
      <% } %>
      <div class="infak-modal-meta">
        <span class="infak-meta-pill">
          <i class="fas fa-users"></i>
          <strong><%= availableMuzakki.length %></strong> muzakki tersedia
        </span>
        <span class="infak-meta-text">
          <%= hasOptions ? "Pilih muzakki dan isi nominal infak." : "Tidak ada muzakki yang bisa dipilih." %>
        </span>
      </div>
      <div class="infak-rows" id="infakRows">
        <div class="infak-row">
          <div class="infak-field">
            <label class="infak-field-label" for="muzakkiSelect0">Pilih Muzakki</label>
            <select
              name="muzakki_id[]"
              id="muzakkiSelect0"
              class="infak-modal-select infak-searchable-select"
              required
              <%= hasOptions ? "" : "disabled" %>
            >
              <option value="">Pilih muzakki</option>
              <%- optionMarkup %>
            </select>
          </div>
          <div class="infak-field">
            <label class="infak-field-label" for="jumlahInfak0">Jumlah Infak (Rp)</label>
            <input
              type="text"
              name="jumlah[]"
              id="jumlahInfak0"
              class="infak-modal-input infak-rupiah-input"
              inputmode="decimal"
              autocomplete="off"
              placeholder="Rp 0"
              required
              <%= hasOptions ? "" : "disabled" %>
            />
          </div>
          <div class="infak-field">
            <label class="infak-field-label" for="keteranganInfak0">Keterangan</label>
            <input
              type="text"
              name="keterangan[]"
              id="keteranganInfak0"
              class="infak-modal-input"
              placeholder="Contoh: Kembalian pembayaran"
              <%= hasOptions ? "" : "disabled" %>
            />
          </div>
          <button
            type="button"
            class="infak-remove-row"
            aria-label="Hapus baris infak"
            <%= hasOptions ? "" : "disabled" %>
          >
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
      <div class="infak-row-actions">
        <button
          type="button"
          id="addInfakRowBtn"
          class="infak-add-row-btn"
          <%= hasOptions ? "" : "disabled" %>
        >
          <i class="fas fa-plus"></i> Tambah baris
        </button>
      </div>
      <div class="infak-form-footer">
        <p class="infak-form-hint">
          Tambah beberapa entri sekaligus agar pencatatan lebih efisien.
        </p>
        <div class="infak-form-buttons">
          <button type="button" class="infak-modal-cancel" onclick="closeInfakModal()">Batal</button>
          <button
            type="submit"
            class="infak-modal-submit"
            <%= hasOptions ? "" : "disabled" %>
          >
            Simpan Infak
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<template id="infakRowTemplate">
  <div class="infak-row">
    <div class="infak-field">
      <label class="infak-field-label">Pilih Muzakki</label>
      <select name="muzakki_id[]" class="infak-modal-select infak-searchable-select" required>
        <option value="">Pilih muzakki</option>
        <%- optionMarkup %>
      </select>
    </div>
    <div class="infak-field">
      <label class="infak-field-label">Jumlah Infak (Rp)</label>
      <input
        type="text"
        name="jumlah[]"
        class="infak-modal-input infak-rupiah-input"
        inputmode="decimal"
        autocomplete="off"
        placeholder="Rp 0"
        required
      />
    </div>
    <div class="infak-field">
      <label class="infak-field-label">Keterangan</label>
      <input
        type="text"
        name="keterangan[]"
        class="infak-modal-input"
        placeholder="Contoh: Kembalian pembayaran"
      />
    </div>
    <button type="button" class="infak-remove-row" aria-label="Hapus baris infak">
      <i class="fas fa-trash"></i>
    </button>
  </div>
</template>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
  (function () {
    const form = document.getElementById("infakModalForm");
    if (!form) return;

    function formatRupiahInput(value) {
      const normalized = String(value || "")
        .replace(/[^0-9,]/g, "")
        .replace(/,+/g, ",");

      const parts = normalized.split(",");
      const integer = (parts[0] || "").replace(/^0+(?=\d)/, "");
      const decimal = parts[1] ? parts[1].slice(0, 2) : "";

      const grouped = integer.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      const withPrefix = grouped ? `Rp ${grouped}` : "";

      return decimal ? `${withPrefix},${decimal}` : withPrefix;
    }

    function toNumericString(value) {
      const cleaned = String(value || "").replace(/[^0-9,]/g, "");
      const parts = cleaned.split(",");
      const integer = (parts[0] || "").replace(/^0+(?=\d)/, "") || "0";
      const decimal = parts[1] ? parts[1].slice(0, 2) : "";
      return decimal ? `${integer}.${decimal}` : integer;
    }

    document.addEventListener("input", function (event) {
      const target = event.target;
      if (!target.classList || !target.classList.contains("infak-rupiah-input")) {
        return;
      }

      const formatted = formatRupiahInput(target.value);
      target.value = formatted;
    });

    document.addEventListener("blur", function (event) {
      const target = event.target;
      if (!target.classList || !target.classList.contains("infak-rupiah-input")) {
        return;
      }

      if (!target.value.trim()) {
        target.value = "";
      }
    }, true);

    form.addEventListener("submit", function () {
      const amountInputs = form.querySelectorAll("input[name='jumlah[]']");
      amountInputs.forEach((input) => {
        if (!input.classList.contains("infak-rupiah-input")) {
          return;
        }
        input.value = toNumericString(input.value);
      });
    });
  })();
</script>
<style>
  #infakModalOverlay.infak-modal-overlay {
    background: rgba(15, 23, 42, 0.62);
    backdrop-filter: blur(8px);
  }

  #infakModalOverlay .infak-modal-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.22);
    overflow: hidden;
  }

  #infakModalOverlay .infak-modal-header {
    padding: 0 0 6px 0;
    border-bottom: 1px solid #e2e8f0;
  }

  #infakModalOverlay .infak-modal-kicker {
    margin: 0;
    color: #0f766e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.45px;
    text-transform: uppercase;
  }

  #infakModalOverlay .infak-modal-title {
    margin: 4px 0 6px;
    font-size: 24px;
    font-weight: 800;
    color: #0f172a;
  }

  #infakModalOverlay .infak-modal-subtitle {
    margin: 0;
    color: #64748b;
    font-size: 13px;
    line-height: 1.5;
  }

  #infakModalOverlay .infak-modal-close {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #334155;
  }

  #infakModalOverlay .infak-modal-close:hover {
    background: #eef2f7;
  }

  #infakModalOverlay .infak-modal-form {
    margin-top: 14px;
    padding: 0;
    gap: 18px;
  }

  #infakModalOverlay .infak-modal-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid #dbeafe;
    background: #f8fbff;
    border-radius: 12px;
    padding: 12px 14px;
  }

  #infakModalOverlay .infak-meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #1d4ed8;
    font-size: 13px;
    font-weight: 700;
  }

  #infakModalOverlay .infak-meta-pill strong {
    font-size: 14px;
  }

  #infakModalOverlay .infak-meta-text {
    color: #64748b;
    font-size: 12px;
    font-weight: 600;
    text-align: right;
  }

  #infakModalOverlay .infak-rows {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  #infakModalOverlay .infak-row {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.2fr auto;
    gap: 14px;
    align-items: end;
    padding: 16px;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    background: #ffffff;
  }

  #infakModalOverlay .infak-field {
    min-width: 0;
  }

  #infakModalOverlay .infak-field-label {
    display: block;
    margin-bottom: 8px;
    color: #475569;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  #infakModalOverlay .infak-modal-select,
  #infakModalOverlay .infak-modal-input {
    width: 100%;
    height: 44px;
    padding: 0 14px;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    background: #ffffff;
    color: #0f172a;
    font-size: 14px;
    font-weight: 600;
    box-shadow: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  #infakModalOverlay .infak-rupiah-input {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  #infakModalOverlay .infak-modal-select:focus,
  #infakModalOverlay .infak-modal-input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.14);
  }

  #infakModalOverlay .infak-remove-row {
    width: 42px;
    height: 42px;
    border: 1px solid #fecaca;
    border-radius: 10px;
