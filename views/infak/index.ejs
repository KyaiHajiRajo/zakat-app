<!-- JavaScript -->
  <script>
    // Add entrance animations on load
    document.addEventListener('DOMContentLoaded', function () {
      // Animate stat boxes
    const statBoxes = document.querySelectorAll('.stat-box');
    statBoxes.forEach((box, index) => {
      box.style.opacity = '0';
      box.style.transform = 'translateY(20px)';
      setTimeout(() => {
        box.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
        box.style.opacity = '1';
        box.style.transform = 'translateY(0)';
      }, index * 100);
    });

    // Animate info boxes
    const infoBoxes = document.querySelectorAll('.info-box-item');
    infoBoxes.forEach((box, index) => {
      box.style.opacity = '0';
      box.style.transform = 'translateY(20px)';
      setTimeout(() => {
        box.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
        box.style.opacity = '1';
        box.style.transform = 'translateY(0)';
      }, (statBoxes.length * 100) + (index * 150));
      });
    });
  </script>

  <script>
    (function () {
      const overlay = document.getElementById("infakModalOverlay");
      if (!overlay) return;

      const openButton = document.getElementById("openInfakModalBtn");
      const addRowButton = document.getElementById("addInfakRowBtn");
      const rowContainer = document.getElementById("infakRows");
      const rowTemplate = document.getElementById("infakRowTemplate");
      const body = document.body;
      const modalCard = overlay.querySelector(".infak-modal-card");
      const hasJQuery = typeof window.jQuery !== "undefined";
      const canUseSelect2 =
        hasJQuery &&
        typeof window.jQuery.fn !== "undefined" &&
        typeof window.jQuery.fn.select2 === "function";
      let rowIdCounter = 0;

      function toggleBodyScroll(disable) {
        body.style.overflow = disable ? "hidden" : "";
      }

      function assignRowIdentifiers(row) {
        if (!row) return;

        rowIdCounter += 1;

        const select = row.querySelector("select[name='muzakki_id[]']");
        const jumlahInput = row.querySelector("input[name='jumlah[]']");
        const keteranganInput = row.querySelector("input[name='keterangan[]']");
        const labels = row.querySelectorAll(".infak-field-label");

        if (select) {
          const selectId = `muzakkiSelect${rowIdCounter}`;
          select.id = selectId;
          if (labels[0]) {
            labels[0].setAttribute("for", selectId);
          }
        }

        if (jumlahInput) {
          const jumlahId = `jumlahInfak${rowIdCounter}`;
          jumlahInput.id = jumlahId;
          if (labels[1]) {
            labels[1].setAttribute("for", jumlahId);
          }
        }

        if (keteranganInput) {
          const keteranganId = `keteranganInfak${rowIdCounter}`;
          keteranganInput.id = keteranganId;
          if (labels[2]) {
            labels[2].setAttribute("for", keteranganId);
          }
        }
      }

      function initializeSearchableSelect(select) {
        if (!select || !canUseSelect2) {
          return;
        }

        const $select = window.jQuery(select);
        if ($select.hasClass("select2-hidden-accessible")) {
          return;
        }

        $select.select2({
          width: "100%",
          placeholder: "Cari atau pilih muzakki",
          allowClear: true,
          minimumResultsForSearch: 0,
          dropdownParent: window.jQuery(modalCard),
          containerCssClass: "infak-select2-wrapper",
          dropdownCssClass: "infak-select2-dropdown",
          language: {
            noResults: function () {
              return "Muzakki tidak ditemukan";
            },
            searching: function () {
              return "Mencari muzakki...";
            },
          },
        });

        $select.on("select2:open", function () {
          const searchField = document.querySelector(
            ".select2-container--open .select2-search__field"
          );
          if (searchField) {
            searchField.focus();
          }
        });
      }

      function initializeAllSearchableSelects() {
        rowContainer
          .querySelectorAll("select[name='muzakki_id[]']")
          .forEach(initializeSearchableSelect);
      }

      function refreshSelectOptions() {
        const selects = rowContainer.querySelectorAll("select[name='muzakki_id[]']");
        const selected = Array.from(selects)
          .map((select) => select.value)
          .filter(Boolean);

        selects.forEach((select) => {
          select.querySelectorAll("option").forEach((option) => {
            option.disabled =
              option.value &&
              option.value !== select.value &&
              selected.includes(option.value);
          });

          if (canUseSelect2) {
            window.jQuery(select).trigger("change.select2");
          }
        });
      }

      function updateRemoveButtons() {
        const rows = rowContainer.querySelectorAll(".infak-row");
        const disable = rows.length === 1;
        rows.forEach((row) => {
          const button = row.querySelector(".infak-remove-row");
          if (button) {
            button.disabled = disable;
          }
        });
      }

      function appendRow() {
        if (!rowTemplate) return;
        const clone = rowTemplate.content.cloneNode(true);
        const row = clone.querySelector(".infak-row");
        rowContainer.appendChild(clone);
        assignRowIdentifiers(row);
        initializeSearchableSelect(
          row && row.querySelector("select[name='muzakki_id[]']")
        );
        refreshSelectOptions();
        updateRemoveButtons();
      }

      function removeRow(button) {
        const row = button.closest(".infak-row");
        if (!row) return;
        if (rowContainer.querySelectorAll(".infak-row").length === 1) {
          return;
        }

        const select = row.querySelector("select[name='muzakki_id[]']");
        if (select && canUseSelect2) {
          const $select = window.jQuery(select);
          if ($select.hasClass("select2-hidden-accessible")) {
            $select.select2("destroy");
          }
        }

        row.remove();
        refreshSelectOptions();
        updateRemoveButtons();
      }

      function openInfakModal() {
        overlay.classList.remove("hidden");
        toggleBodyScroll(true);
        initializeAllSearchableSelects();
        refreshSelectOptions();
        updateRemoveButtons();
      }

      function closeInfakModal() {
        if (canUseSelect2) {
          window
            .jQuery(rowContainer.querySelectorAll("select[name='muzakki_id[]']"))
            .select2("close");
        }
        overlay.classList.add("hidden");
        toggleBodyScroll(false);
      }

      overlay.addEventListener("click", (event) => {
        if (event.target === overlay) {
          closeInfakModal();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !overlay.classList.contains("hidden")) {
          closeInfakModal();
        }
      });

      rowContainer.addEventListener("click", (event) => {
        if (event.target.closest(".infak-remove-row")) {
          event.preventDefault();
          removeRow(event.target.closest(".infak-remove-row"));
        }
      });

      rowContainer.addEventListener("change", (event) => {
        if (event.target.matches("select[name='muzakki_id[]']")) {
          refreshSelectOptions();
        }
      });

      if (openButton) {
        openButton.addEventListener("click", (event) => {
          event.preventDefault();
          openInfakModal();
        });
      }

      if (addRowButton) {
        addRowButton.addEventListener("click", (event) => {
          event.preventDefault();
          appendRow();
        });
      }

      rowContainer.querySelectorAll(".infak-row").forEach(assignRowIdentifiers);
      initializeAllSearchableSelects();
      refreshSelectOptions();
      updateRemoveButtons();

      window.closeInfakModal = closeInfakModal;
    })();
  </script>

  <script>
    (function () {
      const deleteForms = document.querySelectorAll(".infak-delete-form");
      if (!deleteForms.length) return;

      deleteForms.forEach((form) => {
        form.addEventListener("submit", async (event) => {
          if (form.dataset.submitting === "true") {
            return;
          }

          event.preventDefault();

          const muzakkiName = form.dataset.muzakkiName || "muzakki ini";
          const jumlah = form.dataset.jumlah ? `Rp ${form.dataset.jumlah}` : "";
          const deleteMessage = jumlah
            ? `Data infak ${muzakkiName} (${jumlah}) akan dihapus permanen.`
            : `Data infak ${muzakkiName} akan dihapus permanen.`;

          let confirmationResult = { isConfirmed: false };
          if (typeof showDeleteConfirm === "function") {
            confirmationResult = await showDeleteConfirm(
              `infak ${muzakkiName}`,
              deleteMessage
            );
          } else if (typeof Swal !== "undefined") {
            confirmationResult = await Swal.fire({
              icon: "warning",
              title: "Konfirmasi Hapus",
              text: deleteMessage,
              showCancelButton: true,
              confirmButtonText: "Ya, Hapus",
              cancelButtonText: "Batal",
              confirmButtonColor: "#ef4444",
              cancelButtonColor: "#6b7280",
            });
          } else {
            confirmationResult.isConfirmed = window.confirm(deleteMessage);
          }

          if (!confirmationResult.isConfirmed) {
            return;
          }

          form.dataset.submitting = "true";
          form.submit();
        });
      });
    })();
  </script>

