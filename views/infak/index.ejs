<%- include('../layouts/header', { title: 'Data Infak - Zakat Fitrah App',
bodyClass: 'bg-gray-50 min-h-screen', currentPage: 'infak' }) %>

<%
  const availableMuzakkiList = Array.isArray(availableMuzakki) ? availableMuzakki : [];
  const hasAvailableInfakTargets = availableMuzakkiList.length > 0;
%>

<div class="page-wrapper">
  <!-- Modern Header -->
  <div class="page-header">
    <div class="header-content-wrapper">
      <div class="header-left-section">
        <div class="header-icon-box">
          <img src="/images/logo-dkm.png" alt="Logo DKM" class="header-logo">
        </div>
        <div class="header-text-box">
          <h1 class="header-title-text">Data Infak</h1>
          <p class="header-subtitle-text">Daftar infak yang terkumpul dari kembalian zakat</p>
        </div>
      </div>
      <div class="header-actions">
        <button
          type="button"
          id="openInfakModalBtn"
          class="btn-add-infak"
          <%= hasAvailableInfakTargets ? "" : "disabled" %>
        >
          <i class="fas fa-hand-holding-heart mr-2"></i>
          Tambah Sodakoh
        </button>
        <span class="header-action-hint">
          <%= hasAvailableInfakTargets ? "Tambah entri infak baru dari muzakki tanpa catatan sebelumnya" : "Semua muzakki sudah memiliki catatan infak" %>
        </span>
      </div>
    </div>
  </div>

  <% if (success_msg && success_msg.length > 0) { %>
    <div class="alert-banner alert-success">
      <i class="fas fa-check-circle"></i>
      <span><%= success_msg.join(" ") %></span>
    </div>
  <% } %>
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="alert-banner alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= error_msg.join(" ") %></span>
    </div>
  <% } %>

  <!-- Statistics Cards -->
  <div class="stats-container">
    <div class="stat-box stat-box-primary">
      <div class="stat-icon-wrapper stat-icon-primary">
        <i class="fas fa-coins"></i>
      </div>
      <div class="stat-content-box">
        <div class="stat-value-text">
          Rp <%= Math.floor(infak.reduce((total, item) => total +
          (parseFloat(item.jumlah) || 0), 0)).toLocaleString('id-ID') %>
        </div>
        <div class="stat-label-text">Total Infak Terkumpul</div>
      </div>
      <div class="stat-decoration"></div>
    </div>

    <div class="stat-box stat-box-success">
      <div class="stat-icon-wrapper stat-icon-success">
        <i class="fas fa-exchange-alt"></i>
      </div>
      <div class="stat-content-box">
        <div class="stat-value-text">
          <%= infak.length %>
        </div>
        <div class="stat-label-text">Total Transaksi Infak</div>
      </div>
      <div class="stat-decoration"></div>
    </div>

    <div class="stat-box stat-box-info">
      <div class="stat-icon-wrapper stat-icon-info">
        <i class="fas fa-calculator"></i>
      </div>
      <div class="stat-content-box">
        <div class="stat-value-text">
          <% if (infak.length > 0) { %>
            Rp <%= Math.floor((infak.reduce((total, item) => total + (parseFloat(item.jumlah) || 0), 0)) / infak.length).toLocaleString('id-ID') %>
          <% } else { %>
            Rp 0
          <% } %>
        </div>
        <div class="stat-label-text">Rata-rata Per Transaksi</div>
      </div>
      <div class="stat-decoration"></div>
    </div>
  </div>

  <!-- Data Table Section -->
  <div class="table-section">
    <div class="table-header-wrapper">
      <div class="table-header-left">
        <div class="table-header-icon">
          <i class="fas fa-table"></i>
        </div>
        <div class="table-header-text">
          <h2 class="table-title">Daftar Transaksi Infak</h2>
          <p class="table-subtitle">Riwayat lengkap infak dari kembalian zakat</p>
        </div>
      </div>
      <div class="table-header-right">
        <span class="table-badge">
          <i class="fas fa-list"></i>
          <%= infak.length %> Transaksi
        </span>
      </div>
    </div>

    <div class="table-content-wrapper">
      <% if (infak.length === 0) { %>
        <div class="empty-state-box">
          <div class="empty-state-icon">
            <i class="fas fa-hand-holding-heart"></i>
          </div>
          <h3 class="empty-state-title">Belum ada infak</h3>
          <p class="empty-state-desc">Infak akan muncul otomatis ketika ada kembalian zakat yang disedekahkan</p>
          <a href="/muzakki" class="btn-empty-state">
            <i class="fas fa-users mr-2"></i>
            Lihat Data Muzakki
          </a>
        </div>
      <% } else { %>
        <div class="table-responsive-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Tanggal</th>
                <th>Dari Muzakki</th>
                <th>RT</th>
                <th>Jumlah Infak</th>
                <th>Keterangan</th>
                <th class="text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% infak.forEach(function(item, index) { %>
              <tr class="table-row-animated" style="animation-delay: <%= index * 0.05 %>s;">
                <td>
                  <div class="cell-content-primary">
                    <div class="date-display">
                      <i class="fas fa-calendar-alt mr-2"></i>
                      <%= new Date(item.created_at).toLocaleDateString('id-ID', {
                        weekday: 'short', year: 'numeric', month: 'short', day: 'numeric'
                      }) %>
                    </div>
                    <div class="time-display">
                      <i class="fas fa-clock mr-1"></i>
                      <%= new Date(item.created_at).toLocaleTimeString('id-ID', {
                        hour: '2-digit', minute: '2-digit'
                      }) %>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="cell-content-primary">
                    <div class="muzakki-name">
                      <%= item.muzakki_name || '-' %>
                    </div>
                    <div class="muzakki-id">
                      ID: <%= item.muzakki_id %>
                    </div>
                  </div>
                </td>
                <td class="text-center">
                  <% if (item.nomor_rt) { %>
                    <span class="rt-badge-small">
                      <i class="fas fa-home"></i>
                      RT <%= item.nomor_rt %>
                    </span>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <div class="amount-display-large amount-primary">
                    <i class="fas fa-coins mr-1"></i>
                    Rp <%= Math.floor(item.jumlah).toLocaleString('id-ID') %>
                  </div>
                </td>
                <td>
                  <div class="keterangan-text">
                    <%= item.keterangan || '-' %>
                  </div>
                </td>
                <td class="text-center infak-action-cell">
                  <form
                    method="POST"
                    action="/infak/<%= item.id %>?_method=DELETE"
                    class="infak-delete-form"
                    data-muzakki-name="<%= item.muzakki_name || ('Muzakki #' + item.muzakki_id) %>"
                    data-jumlah="<%= Math.floor(item.jumlah).toLocaleString('id-ID') %>"
                  >
                    <button type="submit" class="infak-delete-btn" aria-label="Hapus data infak">
                      <i class="fas fa-trash-alt"></i>
                      <span>Hapus</span>
                    </button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <div class="table-total-summary">
          <div class="table-total-label">
            <i class="fas fa-calculator mr-2"></i>
            Total Infak
          </div>
          <div class="table-total-value">
            Rp <%= Math.floor(infak.reduce((total, item) => total +
            (parseFloat(item.jumlah) || 0), 0)).toLocaleString('id-ID') %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Information Card -->
  <div class="info-card-section">
    <div class="info-card-header">
      <div class="info-card-icon">
        <i class="fas fa-info-circle"></i>
      </div>
      <h3 class="info-card-title">Informasi Infak</h3>
    </div>
    <div class="info-card-content">
      <div class="info-box-item">
        <div class="info-box-header">
          <i class="fas fa-hand-holding-usd info-icon"></i>
          <h4 class="info-box-title">Sumber Infak</h4>
        </div>
        <ul class="info-list">
          <li><i class="fas fa-check-circle"></i> Kembalian dari pembayaran zakat fitrah</li>
          <li><i class="fas fa-check-circle"></i> Otomatis tercatat saat kembalian disedekahkan</li>
          <li><i class="fas fa-check-circle"></i> Dapat digunakan untuk keperluan sosial</li>
        </ul>
      </div>
      <div class="info-box-item">
        <div class="info-box-header">
          <i class="fas fa-hands-helping info-icon"></i>
          <h4 class="info-box-title">Pemanfaatan</h4>
        </div>
        <ul class="info-list">
          <li><i class="fas fa-check-circle"></i> Bantuan untuk mustahik</li>
          <li><i class="fas fa-check-circle"></i> Kegiatan sosial masyarakat</li>
          <li><i class="fas fa-check-circle"></i> Operasional kegiatan zakat</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/modal-add-infak', { availableMuzakki: availableMuzakkiList }) %>

  <!-- Modern Styles -->
<style>
  /* Page Wrapper */
  .page-wrapper {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, #1EAF2F 0%, #16a127 50%, #0f8a1f 100%);
    border-radius: 20px;
    padding: 16px;
    box-shadow: 0 10px 30px rgba(30, 175, 47, 0.25);
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    animation: pulse-animation 4s ease-in-out infinite;
  }

  @keyframes pulse-animation {
    0%, 100% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.8;
    }
  }

  .header-content-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-add-infak {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 18px;
    border-radius: 999px;
    border: none;
    background: linear-gradient(135deg, #FEBD2E 0%, #F97316 100%);
    color: #1d2632;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    box-shadow: 0 12px 30px rgba(248, 113, 113, 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-add-infak:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    box-shadow: none;
  }

  .btn-add-infak:not(:disabled):hover {
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(249, 115, 22, 0.35);
  }

  .header-action-hint {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
  }

  .alert-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    border-radius: 14px;
    border: 1px solid transparent;
    font-weight: 600;
    font-size: 14px;
  }

  .alert-banner i {
    font-size: 16px;
  }

  .alert-success {
    background: rgba(16, 185, 129, 0.14);
    border-color: rgba(16, 185, 129, 0.4);
    color: #047857;
  }

  .alert-error {
    background: rgba(239, 68, 68, 0.14);
    border-color: rgba(239, 68, 68, 0.45);
    color: #b91c1c;
  }

  .header-left-section {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header-icon-box {
    width: 64px;
    height: 64px;
    background: white;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: white;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    padding: 8px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .header-text-box {
    color: white;
  }

  .header-title-text {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 6px 0;
    color: white;
  }

  .header-subtitle-text {
    font-size: 16px;
    margin: 0;
    color: rgba(255, 255, 255, 0.95);
  }

  /* Statistics Container */
  .stats-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .stat-box {
    background: white;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e7eb;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .stat-box:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.15);
  }

  .stat-decoration {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    opacity: 0.1;
  }

  .stat-box-primary .stat-decoration {
    background: #1EAF2F;
  }

  .stat-box-success .stat-decoration {
    background: #10b981;
  }

  .stat-box-info .stat-decoration {
    background: #3b82f6;
  }

  .stat-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: white;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .stat-icon-primary {
    background: linear-gradient(135deg, #1EAF2F 0%, #16a127 100%);
  }

  .stat-icon-success {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  }

  .stat-icon-info {
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  }

  .stat-content-box {
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .stat-value-text {
    font-size: 24px;
    font-weight: 700;
    color: #111827;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .stat-label-text {
    font-size: 14px;
    color: #6b7280;
    font-weight: 500;
  }

  /* Table Section */
  .table-section {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }

  .table-header-wrapper {
    background: linear-gradient(to right, #f9fafb, #f3f4f6);
    padding: 16px;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .table-header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .table-header-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #1EAF2F 0%, #16a127 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
  }

  .table-title {
    font-size: 22px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 4px 0;
  }

  .table-subtitle {
    font-size: 14px;
    color: #6b7280;
    margin: 0;
  }

  .table-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: #d1fae5;
    color: #065f46;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }

  .table-content-wrapper {
    padding: 16px;
  }

  /* Empty State */
  .empty-state-box {
    text-align: center;
    padding: 60px 24px;
  }

  .empty-state-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 36px;
    color: #9ca3af;
  }

  .empty-state-title {
    font-size: 20px;
    font-weight: 600;
    color: #111827;
    margin: 0 0 8px 0;
  }

  .empty-state-desc {
    font-size: 15px;
    color: #6b7280;
    margin: 0 0 28px 0;
  }

  .btn-empty-state {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #1EAF2F 0%, #16a127 100%);
    color: white;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(30, 175, 47, 0.3);
  }

  .btn-empty-state:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(30, 175, 47, 0.4);
  }

  /* Data Table */
  .table-responsive-wrapper {
    overflow-x: auto;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    padding: 10px;
  }

  .data-table {
    width: 100%;
    min-width: 760px;
    border-collapse: separate;
    border-spacing: 0 8px;
  }

  .data-table thead tr {
    background: transparent;
    border-bottom: 0;
  }

  .data-table th {
    padding: 0 14px 10px;
    text-align: left;
    font-size: 11px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.65px;
    white-space: nowrap;
  }

  .data-table tbody tr {
    transition: all 0.3s ease;
    opacity: 0;
    animation: fadeInRow 0.5s ease forwards;
  }

  @keyframes fadeInRow {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .data-table tbody tr:hover {
    transform: translateY(-2px);
  }

  .data-table tbody td {
    padding: 14px;
    font-size: 14px;
    background: #ffffff;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
    vertical-align: middle;
    box-shadow: 0 3px 10px rgba(15, 23, 42, 0.04);
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .data-table tbody td:first-child {
    border-left: 1px solid #e5e7eb;
    border-radius: 12px 0 0 12px;
  }

  .data-table tbody td:last-child {
    border-right: 1px solid #e5e7eb;
    border-radius: 0 12px 12px 0;
  }

  .data-table tbody tr:hover td {
    background: #f0fdf4;
    border-color: #bbf7d0;
  }

  .data-table td {
    overflow-wrap: anywhere;
  }

  .table-total-summary {
    margin-top: 12px;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    padding: 12px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .table-total-label {
    font-size: 14px;
    color: #0f172a;
    display: inline-flex;
    align-items: center;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .table-total-value {
    font-size: 18px;
    font-weight: 800;
    color: #15803d;
    text-align: right;
    overflow-wrap: anywhere;
  }

  /* Table Cell Content */
  .cell-content-primary {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .date-display {
    font-weight: 600;
    color: #0f172a;
    font-size: 14px;
    display: flex;
    align-items: center;
    line-height: 1.4;
  }

  .date-display i {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #dcfce7;
    color: #166534;
    margin-right: 8px;
  }

  .time-display {
    font-size: 12px;
    color: #64748b;
    display: flex;
    align-items: center;
    font-weight: 500;
  }

  .muzakki-name {
    font-weight: 700;
    color: #0f172a;
    font-size: 15px;
    line-height: 1.35;
  }

  .muzakki-id {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 3px 8px;
    border-radius: 999px;
    font-size: 11px;
    color: #64748b;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
  }

  .text-center {
    text-align: center;
  }

  .text-gray-400 {
    color: #9ca3af;
  }

  .rt-badge-small {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    background: #f1f5f9;
    color: #334155;
    border-radius: 999px;
    border: 1px solid #dbeafe;
    font-weight: 600;
    font-size: 12px;
  }

  .amount-display-large {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 10px;
    border: 1px solid #bbf7d0;
    background: #f0fdf4;
