    font-size: 1.04rem;
  }

  .empty-state p {
    margin: 0;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .public-report-page {
      padding: 12px 10px 18px;
      gap: 12px;
    }

    .public-report-hero {
      border-radius: 18px;
      padding: 16px;
    }

    .hero-actions {
      width: 100%;
      min-width: 0;
    }

    .hero-btn {
      width: 100%;
    }

    .public-stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .panel-header {
      align-items: flex-start;
    }

    .panel-header-controls {
      width: 100%;
      justify-content: flex-start;
    }

    .panel-tabs {
      width: 100%;
    }

    .panel-filters {
      width: 100%;
    }

    .panel-filter-box {
      flex: 1;
      min-width: 0;
    }

    .panel-filter-box input,
    .panel-filter-box select {
      min-width: 0;
      width: 100%;
    }

    .stat-split-head {
      flex-wrap: wrap;
    }

    .stat-split-row {
      grid-template-columns: auto 1fr;
      row-gap: 4px;
    }

    .stat-split-percent {
      grid-column: 2 / 3;
      justify-self: end;
    }

    .public-report-table {
      min-width: 0;
      border-collapse: separate;
      border-spacing: 0;
    }

    .public-report-table thead {
      display: none;
    }

    .public-report-table tr {
      display: block;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      margin-bottom: 12px;
      overflow: hidden;
    }

    .public-report-table td {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      width: 100%;
      text-align: right;
      border-bottom: 1px solid #f1f5f9;
      padding: 10px 12px;
    }

    .public-report-table td:last-child {
      border-bottom: none;
    }

    .public-report-table td::before {
      content: attr(data-label);
      color: #64748b;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      text-align: left;
      flex: 1;
    }
  }

  @media (max-width: 540px) {
    .public-stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-value {
      font-size: 1.05rem;
    }
  }

  @media print {
    .top-navbar,
    .sidebar,
    .sidebar-overlay,
    .hero-actions {
      display: none !important;
    }

    .public-report-page {
      max-width: none;
      padding: 0;
    }
  }
</style>

<script>
  function initHijriDate() {
    const target = document.getElementById("currentHijriDateLabel");
    if (!target) {
      return;
    }

    const now = new Date();
    const hijriCalendars = [
      "islamic-umalqura",
      "islamic",
      "islamic-civil",
      "islamic-tbla",
    ];

    for (const calendarType of hijriCalendars) {
      try {
        const formatter = new Intl.DateTimeFormat("id-ID", {
          calendar: calendarType,
          weekday: "long",
          day: "numeric",
          month: "long",
          year: "numeric",
          timeZone: "Asia/Jakarta",
        });

        const hijriText = formatter.format(now);
        if (hijriText && hijriText.trim().length > 0) {
          target.textContent = hijriText;
          return;
        }
      } catch (error) {
        // Try next supported Hijri calendar variant.
      }
    }

    target.textContent = "Kalender Hijriyah tidak didukung browser ini";
  }

  function initPublicTabs() {
    const tabButtons = Array.from(document.querySelectorAll(".panel-tab"));
    const tabContents = Array.from(document.querySelectorAll(".tab-content"));
    const badge = document.getElementById("panelBadgeCount");
    const searchInput = document.getElementById("panelSearchInput");
    const rtFilter = document.getElementById("panelRtFilter");
    const statsPrimaryValue = document.getElementById("statsPrimaryValue");
    const statsPrimaryLabel = document.getElementById("statsPrimaryLabel");
    const statsSecondaryValue = document.getElementById("statsSecondaryValue");
    const statsSecondaryLabel = document.getElementById("statsSecondaryLabel");
    const statsTertiaryValue = document.getElementById("statsTertiaryValue");
    const statsTertiaryLabel = document.getElementById("statsTertiaryLabel");
    const statsSplitTitle = document.getElementById("statsSplitTitle");
    const statsSplitLabelOne = document.getElementById("statsSplitLabelOne");
    const statsSplitLabelTwo = document.getElementById("statsSplitLabelTwo");
    const statsSplitValueOne = document.getElementById("statsSplitValueOne");
    const statsSplitValueTwo = document.getElementById("statsSplitValueTwo");

    if (!tabButtons.length || !tabContents.length) {
      return;
    }

    let activeTabId = "tabMuzakki";
    const numberFormatter = new Intl.NumberFormat("id-ID");
    const decimalFormatter = new Intl.NumberFormat("id-ID", {
      minimumFractionDigits: 0,
      maximumFractionDigits: 2,
    });

    const normalize = function (value) {
      return String(value || "").toLowerCase().trim();
    };

    const normalizeKategoriLabel = function (value) {
      const source = String(value || "-").trim();
      if (!source || source === "-") return "Lainnya";

      return source
        .split("_")
        .join(" ")
        .replace(/\b\w/g, (char) => char.toUpperCase());
    };

    const setSplitLabelMode = function (mode) {
      if (!statsSplitLabelOne || !statsSplitLabelTwo) return;

      statsSplitLabelOne.classList.remove("stat-split-label-uang", "stat-split-label-beras", "stat-split-label-neutral");
      statsSplitLabelTwo.classList.remove("stat-split-label-uang", "stat-split-label-beras", "stat-split-label-neutral");

      if (mode === "muzakki") {
        statsSplitLabelOne.classList.add("stat-split-label-uang");
        statsSplitLabelTwo.classList.add("stat-split-label-beras");
      } else {
        statsSplitLabelOne.classList.add("stat-split-label-neutral");
        statsSplitLabelTwo.classList.add("stat-split-label-neutral");
      }
    };

    const updateStatistics = function (rows, tabId) {
      if (
        !statsPrimaryValue ||
        !statsPrimaryLabel ||
        !statsSecondaryValue ||
        !statsSecondaryLabel ||
        !statsTertiaryValue ||
        !statsTertiaryLabel ||
        !statsSplitTitle ||
        !statsSplitLabelOne ||
        !statsSplitLabelTwo ||
        !statsSplitValueOne ||
        !statsSplitValueTwo
      ) {
        return;
      }

      if (tabId === "tabMustahik") {
        const kategoriCounter = {};
        let withRtCount = 0;

        rows.forEach((row) => {
          const kategori = normalize(row.dataset.kategori) || "lainnya";
          kategoriCounter[kategori] = (kategoriCounter[kategori] || 0) + 1;

          if (normalize(row.dataset.rt) && normalize(row.dataset.rt) !== "-") {
            withRtCount += 1;
          }
        });

        const sortedKategori = Object.entries(kategoriCounter).sort((a, b) => b[1] - a[1]);
        const topOne = sortedKategori[0] || ["lainnya", 0];
        const topTwo = sortedKategori[1] || ["lainnya", 0];

        statsPrimaryValue.textContent = numberFormatter.format(rows.length);
        statsPrimaryLabel.textContent = "Total Data Mustahik";

        statsSecondaryValue.textContent = `${numberFormatter.format(sortedKategori.length)} kategori`;
        statsSecondaryLabel.textContent = "Kategori Terdata";

        statsTertiaryValue.textContent = `${numberFormatter.format(withRtCount)} data`;
        statsTertiaryLabel.textContent = "Mustahik Terdaftar RT";

        statsSplitTitle.textContent = "Komposisi Kategori";
        statsSplitLabelOne.textContent = normalizeKategoriLabel(topOne[0]);
        statsSplitLabelTwo.textContent = normalizeKategoriLabel(topTwo[0]);
        statsSplitValueOne.textContent = `${numberFormatter.format(topOne[1] || 0)} mustahik`;
        statsSplitValueTwo.textContent = `${numberFormatter.format(topTwo[1] || 0)} mustahik`;
        setSplitLabelMode("mustahik");
        return;
      }

      let totalBayar = 0;
      let totalBeras = 0;
      let countUang = 0;
      let countBeras = 0;

      rows.forEach((row) => {
        const jenis = normalize(row.dataset.jenis);
        const bayar = Number(row.dataset.jumlahBayar || 0);
        const beras = Number(row.dataset.jumlahBeras || 0);

        totalBayar += Number.isFinite(bayar) ? bayar : 0;
        totalBeras += Number.isFinite(beras) ? beras : 0;

        if (jenis === "uang") countUang += 1;
        if (jenis === "beras") countBeras += 1;
      });

      statsPrimaryValue.textContent = numberFormatter.format(rows.length);
      statsPrimaryLabel.textContent = "Total Data Muzakki";

      statsSecondaryValue.textContent = `Rp ${numberFormatter.format(Math.round(totalBayar))}`;
      statsSecondaryLabel.textContent = "Total Jumlah Bayar";

      statsTertiaryValue.textContent = `${decimalFormatter.format(totalBeras)} kg`;
      statsTertiaryLabel.textContent = "Total Jumlah Beras";

      statsSplitTitle.textContent = "Jenis Zakat";
      statsSplitLabelOne.textContent = "Uang";
      statsSplitLabelTwo.textContent = "Beras";
      statsSplitValueOne.textContent = `${numberFormatter.format(countUang)} muzakki`;
      statsSplitValueTwo.textContent = `${numberFormatter.format(countBeras)} muzakki`;
      setSplitLabelMode("muzakki");
    };

    const applyFilters = function () {
      const keyword = normalize(searchInput ? searchInput.value : "");
      const selectedRt = normalize(rtFilter ? rtFilter.value : "");

      tabContents.forEach((content) => {
        const rows = Array.from(content.querySelectorAll("tbody .filterable-row"));
        let visibleCount = 0;

        rows.forEach((row) => {
          const searchText = normalize(row.dataset.search);
          const rowRt = normalize(row.dataset.rt);
          const matchesKeyword = !keyword || searchText.includes(keyword);
          const matchesRt = !selectedRt || rowRt === selectedRt;
          const isVisible = matchesKeyword && matchesRt;

          row.style.display = isVisible ? "" : "none";
          if (isVisible) {
            visibleCount += 1;
          }
        });

        const filterEmpty = document.getElementById(`${content.id}Empty`);
        if (filterEmpty) {
          filterEmpty.hidden = visibleCount > 0 || rows.length === 0;
        }

        content.dataset.visibleCount = String(visibleCount);
      });

      const activeContent = document.getElementById(activeTabId);
      const activeCount = activeContent
        ? Number(activeContent.dataset.visibleCount || 0)
        : 0;

      if (badge) {
        badge.textContent = `${activeCount} baris`;
      }

      const activeRows = activeContent
        ? Array.from(activeContent.querySelectorAll("tbody .filterable-row")).filter(
            (row) => row.style.display !== "none"
          )
        : [];

      updateStatistics(activeRows, activeTabId);
    };

    const activateTab = function (button) {
      const targetId = button.getAttribute("data-tab-target");
      const targetContent = document.getElementById(targetId);
      activeTabId = targetId || activeTabId;

      tabButtons.forEach((item) => item.classList.remove("is-active"));
      tabContents.forEach((item) => item.classList.remove("is-active"));

      button.classList.add("is-active");
      if (targetContent) {
        targetContent.classList.add("is-active");
      }

      applyFilters();
    };

    tabButtons.forEach((button) => {
      button.addEventListener("click", function () {
        activateTab(button);
      });
    });

    if (searchInput) {
      searchInput.addEventListener("input", applyFilters);
    }

    if (rtFilter) {
      rtFilter.addEventListener("change", applyFilters);
    }

    activateTab(tabButtons.find((button) => button.classList.contains("is-active")) || tabButtons[0]);
  }

  function copyPublicLink() {
    const url = window.location.href;
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(function () {
        showSuccess("Link publik berhasil disalin.");
      }).catch(function () {
        showInfo(url, "Salin link berikut");
      });
      return;
    }

    showInfo(url, "Salin link berikut");
  }

  document.addEventListener("DOMContentLoaded", function () {
    initHijriDate();
    initPublicTabs();
  });
</script>

