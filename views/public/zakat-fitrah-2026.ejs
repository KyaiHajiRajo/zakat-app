    font-weight: 700;
  }

  .kategori-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 4px 9px;
    font-size: 0.72rem;
    font-weight: 700;
    background: #ede9fe;
    color: #5b21b6;
    text-transform: capitalize;
  }

  .jenis-uang {
    background: #fee2e2;
    color: #b91c1c;
  }

  .jenis-beras {
    background: #dcfce7;
    color: #166534;
  }

  .empty-state {
    text-align: center;
    padding: 36px 20px;
    color: #64748b;
  }

  .empty-state i {
    font-size: 2rem;
    margin-bottom: 12px;
    color: #94a3b8;
  }

  .empty-state h3 {
    margin: 0 0 6px;
