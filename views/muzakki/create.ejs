<%- include('../layouts/header', { title: 'Tambah Muzakki - Zakat Fitrah App' , bodyClass: 'bg-gray-50' ,
  currentPage: 'muzakki' }) %>

  <div class="page-wrapper">
    <!-- Modern Header -->
    <div class="page-header">
      <div class="header-content-wrapper">
        <div class="header-left-section">
          <a href="/muzakki" class="back-button">
            <i class="fas fa-arrow-left"></i>
          </a>
          <div class="header-icon-box">
            <img src="/images/logo-dkm.png" alt="Logo DKM" class="header-logo">
          </div>
          <div class="header-text-box">
            <h1 class="header-title-text">Tambah Muzakki</h1>
            <p class="header-subtitle-text">Daftarkan muzakki baru dan hitung zakat fitrah</p>
          </div>
        </div>
        <div class="header-actions">
          <div class="info-badge">
            <i class="fas fa-info-circle"></i>
            <span>Form Pendaftaran</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Form Container -->
    <div class="form-container">
      <form action="/muzakki" method="POST" id="muzakkiForm">
        <!-- RT Selection Card -->
        <div class="form-card">
          <div class="card-header">
            <div class="card-header-icon">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <div class="card-header-text">
              <h2 class="card-title">RT dan Tanggal</h2>
              <p class="card-subtitle">Tentukan RT tempat muzakki terdaftar dan tanggal pembayaran zakat</p>
            </div>
          </div>
          <div class="card-body">
            <div class="form-grid">
              <div class="form-group">
                <label for="rt_id" class="form-label">
                  <i class="fas fa-home mr-1"></i>RT <span class="required">*</span>
                </label>
                <select id="rt_id" name="rt_id" required class="form-select">
                  <option value="">Pilih RT</option>
                  <% rtList.forEach(function(rt) { %>
                    <option value="<%= rt.id %>">
                      <%= rt.nomor_rt %> - <%= rt.ketua_rt %>
                    </option>
                    <% }); %>
                </select>
              </div>
              <div class="form-group">
                <label for="tanggal" class="form-label">
                  <i class="fas fa-calendar-alt mr-1"></i>Tanggal <span class="required">*</span>
                </label>
                <input
                  type="date"
                  id="tanggal"
                  name="tanggal"
                  required
                  class="form-input"
                  value="<%= defaultTanggal %>"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Data Identitas Muzakki Card -->
        <div class="form-card">
          <div class="card-header">
            <div class="card-header-icon">
              <i class="fas fa-id-card"></i>
            </div>
            <div class="card-header-text">
              <h2 class="card-title">Data Identitas Muzakki</h2>
              <p class="card-subtitle">Masukkan data lengkap untuk satu atau lebih muzakki</p>
            </div>
          </div>
          <div class="card-body">
            <div id="muzakkiContainer">
              <div class="muzakki-section" data-index="0">
                <div class="muzakki-section-header">
                  <h3 class="muzakki-section-title">
                    <i class="fas fa-user-circle"></i> Muzakki #1
                  </h3>
                  <button type="button" class="btn-remove-muzakki" onclick="removeMuzakkiSection(0)">
                    <i class="fas fa-trash"></i>
                    <span>Hapus</span>
                  </button>
                </div>

                <div class="form-grid">
                  <div class="form-group form-group-full">
                    <label for="nama_0" class="form-label">
                      <i class="fas fa-user mr-1"></i>Nama Muzakki <span class="required">*</span>
                    </label>
                    <input
                      type="text"
                      id="nama_0"
                      name="muzakki[0][nama]"
                      data-field="nama"
                      required
                      class="form-input"
                      maxlength="100"
                      placeholder="Masukkan nama lengkap muzakki"
                    />
                  </div>

                  <div class="form-group">
                    <label for="bin_binti_0" class="form-label">
                      <i class="fas fa-venus-mars mr-1"></i>Bin/Binti
                    </label>
                    <select id="bin_binti_0" name="muzakki[0][bin_binti]" data-field="bin_binti" class="form-select">
                      <option value="">Pilih</option>
                      <option value="bin">Bin (Anak Laki-laki)</option>
                      <option value="binti">Binti (Anak Perempuan)</option>
                    </select>
                    <p class="form-hint">Sesuai field `bin_binti` pada tabel `muzakki`</p>
                  </div>

                  <div class="form-group form-group-double">
                    <label for="nama_orang_tua_0" class="form-label">
                      <i class="fas fa-users mr-1"></i>Nama Orang Tua
                    </label>
                    <input
                      type="text"
                      id="nama_orang_tua_0"
                      name="muzakki[0][nama_orang_tua]"
                      data-field="nama_orang_tua"
                      class="form-input"
                      maxlength="150"
                      placeholder="Masukkan nama ayah atau ibu sesuai bin/binti"
                    />
                    <p class="form-hint">Sesuai field `nama_orang_tua` pada tabel `muzakki`</p>
                  </div>
                </div>

                <div class="form-group form-group-full">
                  <label for="master_zakat_id_0" class="form-label">
                    <i class="fas fa-hand-holding mr-1"></i>Jenis Zakat <span class="required">*</span>
                  </label>
                  <select
                    id="master_zakat_id_0"
                    name="muzakki[0][master_zakat_id]"
                    data-field="master_zakat_id"
                    required
                    class="form-select"
                    onchange="calculateZakatForSection(this.closest('.muzakki-section'))"
                  >
                    <option value="">Pilih jenis zakat</option>
                    <% masterZakatList.forEach(function(zakat) { %>
                      <option value="<%= zakat.id %>" data-harga="<%= zakat.harga %>" data-kg="<%= zakat.kg %>">
                        <%= zakat.nama %>
                        <% if (parseFloat(zakat.kg) > 0) { %>
                          (<%= zakat.kg %> Liter/jiwa)
                        <% } else { %>
                          (Rp <%= Math.floor(parseFloat(zakat.harga)).toLocaleString('id-ID') %>/jiwa)
                        <% } %>
                      </option>
                    <% }); %>
                  </select>
                  <p class="form-hint">
                    Pilih jenis zakat yang berlaku untuk muzakki ini
                  </p>
                </div>

                <div class="form-grid">
                  <div class="form-group">
                    <label for="jumlah_uang_display_0" class="form-label">
                      <i class="fas fa-wallet mr-1"></i>Jumlah Uang
                    </label>
                    <div class="input-with-prefix">
                      <span class="input-prefix">Rp</span>
                      <input
                        type="text"
                        id="jumlah_uang_display_0"
                        data-display="jumlah_uang"
                        class="form-input input-with-prefix-field input-readonly"
                        placeholder="0"
                        readonly
                        title="Otomatis dihitung dari jenis zakat yang dipilih"
                      />
                      <input type="hidden" id="jumlah_uang_0" name="muzakki[0][jumlah_uang]" data-field="jumlah_uang" value="0" />
                      <input type="hidden" id="jenis_zakat_0" name="muzakki[0][jenis_zakat]" data-field="jenis_zakat" value="" />
                    </div>
                    <p class="form-hint">Terisi otomatis sesuai jenis zakat muzakki ini</p>
                  </div>

                  <div class="form-group">
                    <label for="jumlah_beras_kg_display_0" class="form-label">
                      <i class="fas fa-seedling mr-1"></i>Jumlah Beras
                    </label>
                    <div class="input-with-suffix">
                      <input
                        type="text"
                        id="jumlah_beras_kg_display_0"
                        data-display="jumlah_beras_kg"
                        class="form-input input-with-suffix-field input-readonly"
                        placeholder="0"
                        readonly
                        title="Otomatis dihitung dari jenis zakat yang dipilih"
                      />
                      <span class="input-suffix">Liter</span>
                      <input type="hidden" id="jumlah_beras_kg_0" name="muzakki[0][jumlah_beras_kg]" data-field="jumlah_beras_kg" value="0" />
                    </div>
                    <p class="form-hint">Terisi otomatis sesuai jenis zakat muzakki ini</p>
                  </div>

                  <div class="form-group">
                    <label for="jumlah_bayar_display_0" class="form-label">
                      <i class="fas fa-money-bill-wave mr-1"></i>Jumlah Bayar
                    </label>
                    <div class="input-with-prefix">
                      <span class="input-prefix">Rp</span>
                      <input
                        type="text"
                        id="jumlah_bayar_display_0"
                        data-display="jumlah_bayar"
                        class="form-input input-with-prefix-field"
                        placeholder="0"
                        oninput="handleRupiahInput(this)"
                        onblur="finalizeRupiahInput(this)"
                        onfocus="prepareRupiahInput(this)"
                      />
                      <input type="hidden" id="jumlah_bayar_0" name="muzakki[0][jumlah_bayar]" data-field="jumlah_bayar" value="" />
                    </div>
                    <p class="form-hint">Opsional. Kosongkan jika jumlah bayar belum dicatat.</p>
                  </div>
                </div>
              </div>
            </div>

            <button type="button" id="addMuzakkiBtn" class="btn-add-muzakki" onclick="addMuzakkiSection()">
              <i class="fas fa-plus"></i>
              <span>Tambah Muzakki</span>
            </button>
            <p class="form-hint" style="margin-top: 0.5rem;">Gunakan tombol ini untuk menambah section muzakki baru di bawah form yang sudah ada.</p>
          </div>
        </div>

        <!-- Perhitungan Zakat Card -->
        <div class="form-card">
          <div class="card-header">
            <div class="card-header-icon">
              <i class="fas fa-calculator"></i>
            </div>
            <div class="card-header-text">
              <h2 class="card-title">Perhitungan Zakat</h2>
              <p class="card-subtitle">Ringkasan otomatis seluruh muzakki yang ada di form ini</p>
            </div>
          </div>
          <div class="card-body">
            <div class="form-grid">
              <!-- Jumlah Jiwa -->
              <div class="form-group">
                <label for="jumlah_jiwa" class="form-label">
                  <i class="fas fa-users mr-1"></i>Jumlah Jiwa <span class="required">*</span>
                </label>
                <input type="number" id="jumlah_jiwa" name="jumlah_jiwa" required min="1"
                  class="form-input input-readonly" placeholder="1" readonly value="1"
                  title="Otomatis mengikuti jumlah section muzakki" />
                <p class="form-hint">
                  Nilai ini terisi otomatis sesuai jumlah section muzakki di atas
                </p>
              </div>

              <!-- Preview Perhitungan Zakat -->
              <div class="form-group form-group-full">
                <div class="preview-container">
                  <!-- Preview Jumlah Uang -->
                  <div class="preview-box preview-box-blue">
                    <div class="preview-icon">
                      <i class="fas fa-money-bill-wave"></i>
                    </div>
                    <div class="preview-content">
                      <div class="preview-label">Total Zakat (Uang)</div>
                      <div class="preview-value" id="preview_jumlah_uang">Rp 0</div>
                    </div>
                  </div>

                  <!-- Preview Jumlah Beras -->
                  <div class="preview-box preview-box-green">
                    <div class="preview-icon">
                      <i class="fas fa-seedling"></i>
                    </div>
                  <div class="preview-content">
                    <div class="preview-label">Total Zakat (Beras)</div>
                    <div class="preview-value" id="preview_jumlah_beras_kg">0 Liter</div>
                    </div>
                  </div>

                  <div class="preview-box preview-box-cyan">
                    <div class="preview-icon">
                      <i class="fas fa-hand-holding-usd"></i>
                    </div>
                    <div class="preview-content">
                      <div class="preview-label">Estimasi Kembalian</div>
                      <div class="preview-value" id="preview_kembalian">Rp 0</div>
                      <input type="hidden" id="kembalian" name="kembalian" value="0" />
                    </div>
                  </div>
                </div>
              </div>

              <!-- Catatan -->
              <div class="form-group form-group-full">
                <label for="catatan" class="form-label">
                  <i class="fas fa-sticky-note mr-1"></i>Catatan (Opsional)
                </label>
                <textarea id="catatan" name="catatan" rows="3" class="form-textarea"
                  placeholder="Catatan tambahan atau keterangan khusus"></textarea>
              </div>
            </div>
          </div>
        </div>

        <!-- Submit Buttons -->
        <div class="form-actions">
          <a href="/muzakki" class="btn-secondary">
            <i class="fas fa-times"></i>
            <span>Batal</span>
          </a>
          <button type="submit" class="btn-primary">
            <i class="fas fa-save"></i>
            <span>Simpan Data</span>
          </button>
        </div>
      </form>
    </div>

    <!-- Helper Information -->
    <div class="info-grid">
      <div class="info-card info-card-green">
        <div class="info-card-icon">
          <i class="fas fa-seedling"></i>
        </div>
        <div class="info-card-content">
          <h3 class="info-card-title">Zakat Beras</h3>
          <ul class="info-card-list">
            <li>Kewajiban: 2.5 Liter per jiwa</li>
            <li>Dapat dibayar dengan beras atau uang senilai</li>
            <li>Lebih mudah untuk distribusi</li>
          </ul>
        </div>
      </div>

      <div class="info-card info-card-blue">
        <div class="info-card-icon">
          <i class="fas fa-coins"></i>
        </div>
        <div class="info-card-content">
          <h3 class="info-card-title">Zakat Uang</h3>
          <ul class="info-card-list">
            <li>Kewajiban: Rp 45.000 per jiwa</li>
            <li>Lebih fleksibel untuk pengelolaan</li>
            <li>Mudah untuk perhitungan dan distribusi</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Modern Styles -->
  <style>
    .page-wrapper {
      --mz-primary: #15803d;
      --mz-primary-soft: #22c55e;
      max-width: 100%;
      width: 100%;
      margin: 0 auto;
      padding: 0.62rem 0.22rem 1.35rem;
      display: flex;
      flex-direction: column;
      gap: 0.88rem;
      position: relative;
      min-width: 0;
    }
    .page-wrapper::before,
    .page-wrapper::after {
      content: "";
      position: absolute;
      border-radius: 9999px;
      pointer-events: none;
      filter: blur(10px);
      z-index: 0;
    }
    .page-wrapper::before {
      width: 220px;
      height: 220px;
      top: 18px;
      right: -68px;
      background: radial-gradient(circle at center, rgba(34, 197, 94, 0.2), rgba(34, 197, 94, 0));
    }
    .page-wrapper::after {
      width: 170px;
      height: 170px;
      bottom: 80px;
      left: -46px;
      background: radial-gradient(circle at center, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0));
    }
