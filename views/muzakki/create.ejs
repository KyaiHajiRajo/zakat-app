  </style>


  <script>
    const masterZakatOptionsHtml = `
      <option value="">Pilih jenis zakat</option>
      <% masterZakatList.forEach(function(zakat) { %>
        <option value="<%= zakat.id %>" data-harga="<%= zakat.harga %>" data-kg="<%= zakat.kg %>">
          <%= zakat.nama %>
          <% if (parseFloat(zakat.kg) > 0) { %>
            (<%= zakat.kg %> kg/jiwa)
          <% } else { %>
            (Rp <%= Math.floor(parseFloat(zakat.harga)).toLocaleString('id-ID') %>/jiwa)
          <% } %>
        </option>
      <% }); %>
    `;

    let muzakkiCount = 1;

    function getMuzakkiSections() {
      return Array.from(document.querySelectorAll(".muzakki-section"));
    }

    function getSectionByIndex(index) {
      return document.querySelector(`.muzakki-section[data-index="${index}"]`);
    }

    function getSectionField(section, selector) {
      return section ? section.querySelector(selector) : null;
    }

    // Rupiah formatting functions
    function formatToRupiah(number) {
      if (!number || number === 0) return "0";
      return new Intl.NumberFormat("id-ID").format(number);
    }

    function formatKgValue(number) {
      if (!number || number === 0) return "0";
      return new Intl.NumberFormat("id-ID", {
        minimumFractionDigits: Number.isInteger(number) ? 0 : 1,
        maximumFractionDigits: 2,
      }).format(number);
    }

    function buildMuzakkiSection(index) {
      return `
        <div class="muzakki-section" data-index="${index}">
          <div class="muzakki-section-header">
            <h3 class="muzakki-section-title">
              <i class="fas fa-user-circle"></i> Muzakki #${index + 1}
            </h3>
            <button type="button" class="btn-remove-muzakki" onclick="removeMuzakkiSection(${index})">
              <i class="fas fa-trash"></i>
              <span>Hapus</span>
            </button>
          </div>

          <div class="form-grid">
            <div class="form-group form-group-full">
              <label for="nama_${index}" class="form-label">
                <i class="fas fa-user mr-1"></i>Nama Muzakki <span class="required">*</span>
              </label>
              <input
                type="text"
                id="nama_${index}"
                name="muzakki[${index}][nama]"
                data-field="nama"
                required
                class="form-input"
                maxlength="100"
                placeholder="Masukkan nama lengkap muzakki"
              />
            </div>

            <div class="form-group">
              <label for="bin_binti_${index}" class="form-label">
                <i class="fas fa-venus-mars mr-1"></i>Bin/Binti
              </label>
              <select id="bin_binti_${index}" name="muzakki[${index}][bin_binti]" data-field="bin_binti" class="form-select">
                <option value="">Pilih</option>
                <option value="bin">Bin (Anak Laki-laki)</option>
                <option value="binti">Binti (Anak Perempuan)</option>
              </select>
              <p class="form-hint">Sesuai field \`bin_binti\` pada tabel \`muzakki\`</p>
            </div>

            <div class="form-group form-group-double">
              <label for="nama_orang_tua_${index}" class="form-label">
                <i class="fas fa-users mr-1"></i>Nama Orang Tua
              </label>
              <input
                type="text"
                id="nama_orang_tua_${index}"
                name="muzakki[${index}][nama_orang_tua]"
                data-field="nama_orang_tua"
                class="form-input"
                maxlength="150"
                placeholder="Masukkan nama ayah atau ibu sesuai bin/binti"
              />
              <p class="form-hint">Sesuai field \`nama_orang_tua\` pada tabel \`muzakki\`</p>
            </div>
          </div>

          <div class="form-group form-group-full">
            <label for="master_zakat_id_${index}" class="form-label">
              <i class="fas fa-hand-holding mr-1"></i>Jenis Zakat <span class="required">*</span>
            </label>
            <select
              id="master_zakat_id_${index}"
              name="muzakki[${index}][master_zakat_id]"
              data-field="master_zakat_id"
              required
              class="form-select"
              onchange="calculateZakatForSection(this.closest('.muzakki-section'))"
            >
              ${masterZakatOptionsHtml}
            </select>
            <p class="form-hint">Pilih jenis zakat yang berlaku untuk muzakki ini</p>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="jumlah_uang_display_${index}" class="form-label">
                <i class="fas fa-wallet mr-1"></i>Jumlah Uang
              </label>
              <div class="input-with-prefix">
                <span class="input-prefix">Rp</span>
                <input
                  type="text"
                  id="jumlah_uang_display_${index}"
                  data-display="jumlah_uang"
                  class="form-input input-with-prefix-field input-readonly"
                  placeholder="0"
                  readonly
                  title="Otomatis dihitung dari jenis zakat yang dipilih"
                />
                <input type="hidden" id="jumlah_uang_${index}" name="muzakki[${index}][jumlah_uang]" data-field="jumlah_uang" value="0" />
                <input type="hidden" id="jenis_zakat_${index}" name="muzakki[${index}][jenis_zakat]" data-field="jenis_zakat" value="" />
              </div>
              <p class="form-hint">Terisi otomatis sesuai jenis zakat muzakki ini</p>
            </div>

            <div class="form-group">
              <label for="jumlah_beras_kg_display_${index}" class="form-label">
                <i class="fas fa-seedling mr-1"></i>Jumlah Beras
              </label>
              <div class="input-with-suffix">
                <input
                  type="text"
                  id="jumlah_beras_kg_display_${index}"
                  data-display="jumlah_beras_kg"
                  class="form-input input-with-suffix-field input-readonly"
                  placeholder="0"
                  readonly
                  title="Otomatis dihitung dari jenis zakat yang dipilih"
                />
                <span class="input-suffix">Liter</span>
                <input type="hidden" id="jumlah_beras_kg_${index}" name="muzakki[${index}][jumlah_beras_kg]" data-field="jumlah_beras_kg" value="0" />
              </div>
              <p class="form-hint">Terisi otomatis sesuai jenis zakat muzakki ini</p>
            </div>

            <div class="form-group">
              <label for="jumlah_bayar_display_${index}" class="form-label">
                <i class="fas fa-money-bill-wave mr-1"></i>Jumlah Bayar
              </label>
              <div class="input-with-prefix">
                <span class="input-prefix">Rp</span>
                <input
                  type="text"
                  id="jumlah_bayar_display_${index}"
                  data-display="jumlah_bayar"
                  class="form-input input-with-prefix-field"
                  placeholder="0"
                  oninput="handleRupiahInput(this)"
                  onblur="finalizeRupiahInput(this)"
                  onfocus="prepareRupiahInput(this)"
                />
                <input type="hidden" id="jumlah_bayar_${index}" name="muzakki[${index}][jumlah_bayar]" data-field="jumlah_bayar" value="" />
              </div>
              <p class="form-hint">Opsional. Kosongkan jika jumlah bayar belum dicatat.</p>
            </div>
          </div>
        </div>
      `;
    }

    function parseFromRupiah(rupiahString) {
      if (!rupiahString) return 0;
      return parseInt(String(rupiahString).replace(/[^\d]/g, ""), 10) || 0;
    }

    function parseNullableFromRupiah(rupiahString) {
      const numericValue = String(rupiahString || "").replace(/[^\d]/g, "");
      return numericValue ? parseInt(numericValue, 10) : null;
    }

    function calculateZakatForSection(sectionOrIndex) {
      const section =
        typeof sectionOrIndex === "object"
          ? sectionOrIndex
          : getSectionByIndex(sectionOrIndex);

      if (!section) {
        return;
      }

      const masterZakatSelect = getSectionField(section, '[data-field="master_zakat_id"]');
      const jumlahUangDisplay = getSectionField(section, '[data-display="jumlah_uang"]');
      const jumlahBerasDisplay = getSectionField(section, '[data-display="jumlah_beras_kg"]');
      const jenisZakatInput = getSectionField(section, '[data-field="jenis_zakat"]');
      const jumlahUangInput = getSectionField(section, '[data-field="jumlah_uang"]');
      const jumlahBerasInput = getSectionField(section, '[data-field="jumlah_beras_kg"]');

      if (!masterZakatSelect) {
        return;
      }

      const selectedOption = masterZakatSelect.options[masterZakatSelect.selectedIndex];
      if (!masterZakatSelect.value || !selectedOption) {
        if (jenisZakatInput) jenisZakatInput.value = "";
        if (jumlahUangInput) jumlahUangInput.value = 0;
        if (jumlahBerasInput) jumlahBerasInput.value = 0;
        if (jumlahUangDisplay) jumlahUangDisplay.value = "0";
        if (jumlahBerasDisplay) jumlahBerasDisplay.value = "0";
        calculateAllTotals();
        return;
      }

      const harga = parseFloat(selectedOption.getAttribute("data-harga")) || 0;
      const kg = parseFloat(selectedOption.getAttribute("data-kg")) || 0;

      if (kg > 0) {
        if (jenisZakatInput) jenisZakatInput.value = "beras";
        if (jumlahUangInput) jumlahUangInput.value = Math.floor(harga);
        if (jumlahBerasInput) jumlahBerasInput.value = kg.toFixed(2);
        if (jumlahUangDisplay) jumlahUangDisplay.value = formatToRupiah(harga);
        if (jumlahBerasDisplay) jumlahBerasDisplay.value = formatKgValue(kg);
      } else {
        if (jenisZakatInput) jenisZakatInput.value = "uang";
        if (jumlahUangInput) jumlahUangInput.value = Math.floor(harga);
        if (jumlahBerasInput) jumlahBerasInput.value = 0;
        if (jumlahUangDisplay) jumlahUangDisplay.value = formatToRupiah(harga);
        if (jumlahBerasDisplay) jumlahBerasDisplay.value = "0";
      }

      calculateAllTotals();
    }

    function calculateAllTotals() {
      let totalUang = 0;
      let totalBeras = 0;
      let totalKembalian = 0;

      getMuzakkiSections().forEach((section) => {
        const jumlahUang = parseInt(getSectionField(section, '[data-field="jumlah_uang"]')?.value, 10) || 0;
        const jumlahBeras = parseFloat(getSectionField(section, '[data-field="jumlah_beras_kg"]')?.value) || 0;
        const jumlahBayar = parseInt(getSectionField(section, '[data-field="jumlah_bayar"]')?.value, 10) || 0;

        totalUang += jumlahUang;
        totalBeras += jumlahBeras;
        totalKembalian += Math.max(0, jumlahBayar - jumlahUang);
      });

      const previewJumlahUang = document.getElementById("preview_jumlah_uang");
      const previewJumlahBerasKg = document.getElementById("preview_jumlah_beras_kg");
      const previewKembalian = document.getElementById("preview_kembalian");
      const inputKembalian = document.getElementById("kembalian");

      if (previewJumlahUang) {
        previewJumlahUang.textContent = `Rp ${formatToRupiah(totalUang)}`;
      }
      if (previewJumlahBerasKg) {
        previewJumlahBerasKg.textContent = `${formatKgValue(totalBeras)} kg`;
      }
      if (previewKembalian) {
        previewKembalian.textContent = `Rp ${formatToRupiah(totalKembalian)}`;
      }
      if (inputKembalian) {
        inputKembalian.value = totalKembalian;
      }
    }

    function handleRupiahInput(input) {
      const section = input.closest(".muzakki-section");
      const hiddenInput = getSectionField(section, '[data-field="jumlah_bayar"]');
      const cursorPosition = input.selectionStart;
      const oldValue = input.value;
      const numberValue = parseNullableFromRupiah(input.value);
      const formattedValue = numberValue === null ? "" : formatToRupiah(numberValue);

      input.value = formattedValue;
      if (hiddenInput) {
        hiddenInput.value = numberValue === null ? "" : numberValue;
      }

      calculateAllTotals();

      const newLength = formattedValue.length;
      const oldLength = oldValue.length;
      const newCursorPosition = cursorPosition + (newLength - oldLength);

      setTimeout(() => {
        if (typeof input.setSelectionRange === "function") {
          input.setSelectionRange(newCursorPosition, newCursorPosition);
        }
      }, 0);
    }

    function prepareRupiahInput(input) {
      const section = input.closest(".muzakki-section");
      const hiddenInput = getSectionField(section, '[data-field="jumlah_bayar"]');
      const hiddenValue = hiddenInput ? hiddenInput.value : "";

      if (hiddenValue) {
        input.value = hiddenValue;
        setTimeout(() => input.select(), 50);
      } else {
        input.value = "";
      }
    }

    function finalizeRupiahInput(input) {
      const section = input.closest(".muzakki-section");
      const hiddenInput = getSectionField(section, '[data-field="jumlah_bayar"]');
      const numericValue = parseNullableFromRupiah(input.value);

      input.value = numericValue === null ? "" : formatToRupiah(numericValue);
      if (hiddenInput) {
        hiddenInput.value = numericValue === null ? "" : numericValue;
      }

      calculateAllTotals();
    }

    function updateMuzakkiCounter() {
      muzakkiCount = getMuzakkiSections().length;
    }

    function updateAddButtonVisibility() {
      const addBtn = document.getElementById("addMuzakkiBtn");
      if (addBtn) {
        addBtn.style.display = "inline-flex";
      }
    }

    function updateMuzakkiNumbers() {
      getMuzakkiSections().forEach((section, index) => {
        section.setAttribute("data-index", index);

        const title = section.querySelector(".muzakki-section-title");
        if (title) {
          title.innerHTML = `<i class="fas fa-user-circle"></i> Muzakki #${index + 1}`;
        }

        const removeBtn = section.querySelector(".btn-remove-muzakki");
        if (removeBtn) {
          removeBtn.setAttribute("onclick", `removeMuzakkiSection(${index})`);
        }

        section.querySelectorAll("input, select").forEach((input) => {
          const name = input.getAttribute("name");
          const id = input.getAttribute("id");

          if (name && name.includes("[")) {
            input.setAttribute("name", name.replace(/\[\d+\]/, `[${index}]`));
          }

          if (id && id.includes("_")) {
            const parts = id.split("_");
            parts[parts.length - 1] = String(index);
            input.setAttribute("id", parts.join("_"));
          }
        });

        section.querySelectorAll("label[for]").forEach((label) => {
          const forAttr = label.getAttribute("for");
          if (forAttr && forAttr.includes("_")) {
            const parts = forAttr.split("_");
            parts[parts.length - 1] = String(index);
            label.setAttribute("for", parts.join("_"));
          }
        });
      });
    }

    function updateJumlahJiwa() {
      const jumlahJiwaInput = document.getElementById("jumlah_jiwa");
      if (jumlahJiwaInput) {
        jumlahJiwaInput.value = getMuzakkiSections().length;
      }
      calculateAllTotals();
    }

    function addMuzakkiSection() {
      const container = document.getElementById("muzakkiContainer");
      if (!container) {
        return;
      }

      const newIndex = getMuzakkiSections().length;
      container.insertAdjacentHTML("beforeend", buildMuzakkiSection(newIndex));

      updateMuzakkiNumbers();
      updateMuzakkiCounter();
      updateJumlahJiwa();
      updateAddButtonVisibility();

      const newSection = container.lastElementChild;
      if (newSection) {
        newSection.scrollIntoView({ behavior: "smooth", block: "center" });
        const namaInput = newSection.querySelector('[data-field="nama"]');
        if (namaInput) {
          setTimeout(() => namaInput.focus(), 200);
        }
      }
    }

    function performRemove(index) {
      const section = getSectionByIndex(index);
      if (!section) {
        return;
      }

      section.style.transition = "all 0.25s ease";
      section.style.opacity = "0";
      section.style.transform = "translateX(-20px)";

      setTimeout(() => {
        section.remove();
        updateMuzakkiNumbers();
        updateMuzakkiCounter();
        updateJumlahJiwa();
        updateAddButtonVisibility();
      }, 250);
    }

    function removeMuzakkiSection(index) {
      if (getMuzakkiSections().length <= 1) {
        if (typeof Swal !== "undefined") {
          Swal.fire({
            icon: "warning",
            title: "Tidak Dapat Dihapus",
            text: "Minimal harus ada 1 muzakki",
            confirmButtonColor: "#1EAF2F",
          });
        } else {
          alert("Minimal harus ada 1 muzakki");
        }
        return;
      }

      const confirmMessage = "Apakah Anda yakin ingin menghapus section muzakki ini?";

      if (typeof Swal !== "undefined") {
        Swal.fire({
          icon: "question",
          title: "Konfirmasi Hapus",
          text: confirmMessage,
          showCancelButton: true,
          confirmButtonText: "Ya, Hapus",
          cancelButtonText: "Batal",
          confirmButtonColor: "#ef4444",
          cancelButtonColor: "#6b7280",
          reverseButtons: true,
        }).then((result) => {
          if (result.isConfirmed) {
            performRemove(index);
          }
        });
      } else if (confirm(confirmMessage)) {
        performRemove(index);
      }
    }

    document.addEventListener("DOMContentLoaded", function () {
      updateMuzakkiNumbers();
      updateMuzakkiCounter();
      updateAddButtonVisibility();
      getMuzakkiSections().forEach((section) => calculateZakatForSection(section));
      updateJumlahJiwa();
    });

    document.addEventListener("keypress", function (e) {
      if (!e.target.matches('input[data-display="jumlah_bayar"]')) {
        return;
      }

      if (
        !/[\d]/.test(e.key) &&
        !["Backspace", "Delete", "Tab", "ArrowLeft", "ArrowRight", "Enter"].includes(e.key)
      ) {
        e.preventDefault();
      }
    });

    document.getElementById("muzakkiForm").addEventListener("submit", function (e) {
      const rtId = document.getElementById("rt_id").value;
      const tanggal = document.getElementById("tanggal").value;
      const jiwa = parseInt(document.getElementById("jumlah_jiwa").value, 10) || 0;
      const sections = getMuzakkiSections();

      if (!rtId) {
        e.preventDefault();
        alert("Pilih RT terlebih dahulu");
        return false;
      }

      if (!tanggal) {
        e.preventDefault();
        alert("Tanggal zakat wajib diisi");
        return false;
      }

      if (jiwa <= 0 || sections.length === 0) {
        e.preventDefault();
        alert("Minimal harus ada 1 muzakki");
        return false;
      }

      let invalidMessage = "";
      let invalidInput = null;

      sections.some((section, index) => {
        const namaInput = getSectionField(section, '[data-field="nama"]');
        const masterZakatSelect = getSectionField(section, '[data-field="master_zakat_id"]');
        const jumlahBayarInput = getSectionField(section, '[data-field="jumlah_bayar"]');
        const jumlahUangInput = getSectionField(section, '[data-field="jumlah_uang"]');
        const jumlahBerasInput = getSectionField(section, '[data-field="jumlah_beras_kg"]');
        const jenisZakatInput = getSectionField(section, '[data-field="jenis_zakat"]');

        const nama = namaInput ? namaInput.value.trim() : "";
        const jumlahBayar = parseInt(jumlahBayarInput?.value, 10) || 0;
        const jumlahUang = parseInt(jumlahUangInput?.value, 10) || 0;
        const jumlahBeras = parseFloat(jumlahBerasInput?.value) || 0;
        const jenisZakat = jenisZakatInput ? jenisZakatInput.value : "";

        if (!nama) {
          invalidMessage = `Nama muzakki #${index + 1} tidak boleh kosong`;
          invalidInput = namaInput;
          return true;
        }

        if (!masterZakatSelect || !masterZakatSelect.value) {
          invalidMessage = `Jenis zakat untuk muzakki #${index + 1} wajib dipilih`;
          invalidInput = masterZakatSelect;
          return true;
        }

        if ((jenisZakat === "uang" && jumlahUang <= 0) || (jenisZakat === "beras" && jumlahBeras <= 0)) {
          invalidMessage = `Perhitungan zakat untuk muzakki #${index + 1} belum valid`;
          invalidInput = masterZakatSelect;
          return true;
        }

        return false;
      });

      if (invalidMessage) {
        e.preventDefault();
        if (invalidInput && typeof invalidInput.focus === "function") {
          invalidInput.focus();
        }

        if (typeof Swal !== "undefined") {
          Swal.fire({
            icon: "error",
            title: "Validasi Gagal",
            text: invalidMessage,
            confirmButtonColor: "#1EAF2F",
          });
        } else {
          alert(invalidMessage);
        }
        return false;
      }

      e.preventDefault();

      const totalUang = sections.reduce((acc, section) => {
        return acc + (parseInt(getSectionField(section, '[data-field="jumlah_uang"]')?.value, 10) || 0);
      }, 0);
      const totalBeras = sections.reduce((acc, section) => {
        return acc + (parseFloat(getSectionField(section, '[data-field="jumlah_beras_kg"]')?.value) || 0);
      }, 0);
      const totalBayar = sections.reduce((acc, section) => {
        return acc + (parseInt(getSectionField(section, '[data-field="jumlah_bayar"]')?.value, 10) || 0);
      }, 0);
      const totalKembalian = Math.max(0, totalBayar - totalUang);
      const namaPreview = sections
        .map((section) => getSectionField(section, '[data-field="nama"]')?.value.trim())
        .filter(Boolean)
        .slice(0, 5)
        .join(", ");
      const ringkasanNama = sections.length > 5 ? `${namaPreview}, dan lainnya` : namaPreview;

      if (typeof Swal !== "undefined") {
        Swal.fire({
          title: "Konfirmasi Data",
          html: `
            <div style="text-align: left; padding: 10px;">
              <p style="margin-bottom: 8px;"><strong>Apakah data yang dimasukkan sudah benar?</strong></p>
              <ul style="list-style: none; padding-left: 0;">
                <li style="margin-bottom: 6px;">Tanggal Zakat: <strong>${new Date(`${tanggal}T00:00:00`).toLocaleDateString("id-ID")}</strong></li>
                <li style="margin-bottom: 6px;">Jumlah Muzakki: <strong>${sections.length} orang</strong></li>
                <li style="margin-bottom: 6px;">Nama Muzakki: <strong>${ringkasanNama}</strong></li>
                <li style="margin-bottom: 6px;">Total Zakat Uang: <strong>Rp ${formatToRupiah(totalUang)}</strong></li>
                <li style="margin-bottom: 6px;">Total Zakat Beras: <strong>${formatKgValue(totalBeras)} kg</strong></li>
                <li style="margin-bottom: 6px;">Total Bayar: <strong>Rp ${formatToRupiah(totalBayar)}</strong></li>
                <li style="margin-bottom: 6px;">Estimasi Kembalian: <strong>Rp ${formatToRupiah(totalKembalian)}</strong></li>
              </ul>
            </div>
          `,
          icon: "question",
          showCancelButton: true,
          confirmButtonColor: "#1EAF2F",
          cancelButtonColor: "#6b7280",
          confirmButtonText: "Ya, Simpan",
          cancelButtonText: "Periksa Lagi",
          reverseButtons: true,
        }).then((result) => {
          if (result.isConfirmed) {
            document.getElementById("muzakkiForm").submit();
          }
        });
      } else {
        const confirmMessage =
          `Apakah data yang dimasukkan sudah benar?\n\n` +
          `- Tanggal Zakat: ${new Date(`${tanggal}T00:00:00`).toLocaleDateString("id-ID")}\n` +
          `- Jumlah Muzakki: ${sections.length} orang\n` +
          `- Nama Muzakki: ${ringkasanNama}\n` +
          `- Total Zakat Uang: Rp ${formatToRupiah(totalUang)}\n` +
          `- Total Zakat Beras: ${formatKgValue(totalBeras)} kg\n` +
          `- Total Bayar: Rp ${formatToRupiah(totalBayar)}\n` +
          `- Estimasi Kembalian: Rp ${formatToRupiah(totalKembalian)}`;

        if (confirm(confirmMessage)) {
          document.getElementById("muzakkiForm").submit();
        }
      }

      return false;
    });
  </script>

  <%- include('../layouts/footer') %>
