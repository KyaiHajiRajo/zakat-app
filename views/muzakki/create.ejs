      border-color: #1d4ed8;
      background: linear-gradient(145deg, rgba(30, 64, 175, 0.35) 0%, rgba(30, 58, 138, 0.26) 100%);
    }
    html.dark-mode .preview-box-green {
      border-color: #047857;
      background: linear-gradient(145deg, rgba(5, 150, 105, 0.34) 0%, rgba(6, 95, 70, 0.22) 100%);
    }
