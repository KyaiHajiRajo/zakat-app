      margin: 0;
      font-size: 0.72rem;
      line-height: 1.46;
      color: #6b7280;
    }
    .input-with-prefix {
      position: relative;
      display: flex;
      align-items: center;
      min-width: 0;
    }
    .input-with-suffix {
      position: relative;
      display: flex;
      align-items: center;
      min-width: 0;
    }
    .input-prefix {
      position: absolute;
      left: 0.74rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: #64748b;
      pointer-events: none;
      z-index: 1;
    }
    .input-with-prefix-field {
      padding-left: 2.1rem;
    }
    .input-suffix {
      position: absolute;
      right: 0.74rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: #64748b;
      pointer-events: none;
      z-index: 1;
    }
    .input-with-suffix-field {
      padding-right: 2.2rem;
    }
    .muzakki-section {
      padding: 0.78rem;
      margin-bottom: 0.62rem;
      border-radius: 13px;
      border: 1px solid #e5e7eb;
      background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
      min-width: 0;
    }
    .muzakki-section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.7rem;
    }
    .muzakki-section-title {
      margin: 0;
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--mz-primary);
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
    }
    .btn-remove-muzakki {
      border: 0;
      border-radius: 9px;
