      align-items: center;
      justify-content: center;
    }
    .header-logo {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .header-text-box {
      min-width: 0;
      color: #fff;
    }
    .header-title-text {
      margin: 0;
      font-size: 1.3rem;
      line-height: 1.18;
