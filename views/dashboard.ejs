    overflow: hidden;
    background:
      radial-gradient(circle at 0% 0%, rgba(134, 239, 172, 0.24), transparent 36%),
      radial-gradient(circle at 100% 0%, rgba(45, 212, 191, 0.18), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(244, 250, 246, 0.92) 100%);
    isolation: isolate;
