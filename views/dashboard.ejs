    overflow: hidden;
    padding: 15px 16px;
    border-radius: 18px;
    border: 1px solid #dce7df;
    background:
      radial-gradient(circle at top right, rgba(34, 197, 94, 0.12), transparent 42%),
      linear-gradient(180deg, #ffffff 0%, #f7fbf7 100%);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.05);
