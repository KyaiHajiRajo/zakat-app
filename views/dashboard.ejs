<%- include('layouts/header', { title: 'Dashboard - Zakat Fitrah App',
bodyClass: 'bg-gray-50', currentPage: 'dashboard' }) %>

<%
  const currencyFormatter = new Intl.NumberFormat('id-ID');
  const berasFormatter = new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
  const overviewTrend = Array.isArray(dashboardTrend) ? dashboardTrend : [];
  const overviewInsights = dashboardInsights || {};
  const averageBayarPerMuzakki = Number(overviewInsights.avg_bayar_per_muzakki || 0);
  const latestTrendPoint = overviewTrend.length > 0 ? overviewTrend[overviewTrend.length - 1] : null;
  const chartRangeLabel = overviewTrend.length > 0
    ? `${overviewTrend[0].label} - ${overviewTrend[overviewTrend.length - 1].label}`
    : 'Belum ada data tren';
%>

<!-- Dashboard Container with Modern Design -->
<div class="dashboard-wrapper">
  <!-- Modern Header Section -->
  <div class="dashboard-header">
    <div class="header-content">
      <div class="header-left">
        <div class="header-icon-wrapper">
          <img src="/images/logo-dkm.png" alt="Logo DKM" class="header-logo">
        </div>
        <div class="header-text">
          <h1 class="header-title">Dashboard</h1>
          <p class="header-subtitle">
            Selamat datang, <span class="header-name"><%= (user && user.name) ? user.name : 'User' %></span>
          </p>
        </div>
      </div>
      <div class="header-right">
        <div class="calendar-combined-card" data-tooltip="Tanggal Masehi dan Hijriyah">
          <div class="calendar-row">
            <div class="calendar-row-label">
            </div>
            <div class="calendar-row-value" id="current-date">Loading...</div>
          </div>
          <div class="calendar-row">
            <div class="calendar-row-label">
            </div>
            <div class="calendar-row-value" id="current-hijri-date">Memuat tanggal Hijriyah...</div>
            <div class="calendar-row-subvalue" id="current-hijri-detail"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="header-decoration"></div>
  </div>

  <section class="overview-shell">
    <div class="overview-header">
      <div class="overview-heading">
        <span class="overview-kicker">Ringkasan Utama</span>
        <h2 class="overview-title">Statistik pengumpulan zakat yang lebih rapi dan mudah dibaca</h2>
        <p class="overview-description">Semua angka diringkas dari data aktual muzakki agar panitia cepat membaca kondisi pemasukan, keterlibatan RT, dan perkembangan pencatatan terakhir.</p>
      </div>
      <div class="overview-meta">
        <span class="overview-pill">
          <i class="fas fa-home"></i>
          <%= stats.total_rt_aktif || 0 %> RT aktif
        </span>
        <span class="overview-pill">
          <i class="fas fa-calendar-days"></i>
          <%= overviewInsights.active_days || 0 %> hari tercatat
        </span>
      </div>
    </div>

    <div class="stats-grid stats-grid-modern">
      <article class="stat-card stat-card-featured stat-card-green" data-stat-card>
        <div class="stat-card-header">
          <div class="stat-card-identity">
            <div class="stat-icon">
              <i class="fas fa-wallet"></i>
            </div>
            <div>
              <div class="stat-badge">Pembayaran</div>
              <div class="stat-overline">Sumber: jumlah_bayar muzakki</div>
            </div>
          </div>
          <div class="stat-trend-indicator">
            <i class="fas fa-sparkles"></i>
          </div>
        </div>
        <div class="stat-content">
          <div class="stat-value">Rp <%= Math.floor(stats.total_jumlah_bayar || 0).toLocaleString('id-ID') %></div>
          <div class="stat-label">Zakat Terkumpul</div>
          <div class="stat-description">Akumulasi pembayaran zakat fitrah yang sudah masuk dan tercatat di dashboard.</div>
        </div>
        <div class="stat-feature-points">
          <span class="stat-chip">
            <i class="fas fa-scale-balanced"></i>
            Rata-rata Rp <%= Math.floor(averageBayarPerMuzakki).toLocaleString('id-ID') %> / muzakki
          </span>
          <span class="stat-chip">
            <i class="fas fa-bolt"></i>
            Puncak bayar: <%= overviewInsights.peak_bayar && overviewInsights.peak_bayar.label ? overviewInsights.peak_bayar.label : '-' %>
          </span>
        </div>
      </article>

      <article class="stat-card stat-card-blue" data-stat-card>
        <div class="stat-card-header">
          <div class="stat-icon">
            <i class="fas fa-users"></i>
          </div>
          <div class="stat-badge">Muzakki</div>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= stats.total_muzakki || 0 %></div>
          <div class="stat-label">Total Muzakki</div>
          <div class="stat-description">Jumlah nama muzakki yang sudah tercatat dalam sistem.</div>
        </div>
        <div class="stat-footer">
          <i class="fas fa-arrow-trend-up"></i>
          <span>Puncak aktivitas: <%= overviewInsights.peak_muzakki && overviewInsights.peak_muzakki.label ? overviewInsights.peak_muzakki.label : '-' %></span>
        </div>
      </article>

      <article class="stat-card stat-card-purple" data-stat-card>
        <div class="stat-card-header">
          <div class="stat-icon">
            <i class="fas fa-hand-holding-heart"></i>
          </div>
          <div class="stat-badge">Infak</div>
        </div>
        <div class="stat-content">
          <div class="stat-value">Rp <%= Math.floor(stats.total_infak || 0).toLocaleString('id-ID') %></div>
          <div class="stat-label">Total Infak</div>
          <div class="stat-description">Dana infak yang terkumpul dari konversi kembalian atau sedekah.</div>
        </div>
        <div class="stat-footer">
          <i class="fas fa-heart"></i>
          <span>Rekap donasi tambahan</span>
        </div>
      </article>

      <article class="stat-card stat-card-red" data-stat-card>
        <div class="stat-card-header">
          <div class="stat-icon">
            <i class="fas fa-seedling"></i>
          </div>
          <div class="stat-badge">Beras</div>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= berasFormatter.format(Number(stats.total_beras_kg || 0)) %> kg</div>
          <div class="stat-label">Jumlah Beras</div>
          <div class="stat-description">Akumulasi beras yang diambil langsung dari kolom `jumlah_beras_kg`.</div>
        </div>
        <div class="stat-footer">
          <i class="fas fa-database"></i>
          <span>Tabel muzakki</span>
        </div>
      </article>

      <article class="stat-card stat-card-orange" data-stat-card>
        <div class="stat-card-header">
          <div class="stat-icon">
            <i class="fas fa-user-shield"></i>
          </div>
          <div class="stat-badge">Akses</div>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= stats.total_users || 0 %></div>
          <div class="stat-label">Total User</div>
          <div class="stat-description">Jumlah pengguna aktif yang bisa mengelola proses pencatatan zakat.</div>
        </div>
        <div class="stat-footer">
          <i class="fas fa-users-cog"></i>
          <span>Panitia terdaftar</span>
        </div>
      </article>
    </div>
  </section>

  <section class="analytics-section">
    <div class="analytics-main-card">
      <div class="analytics-header">
        <div>
          <span class="overview-kicker">Statistik Muzakki</span>
          <h2 class="analytics-title">Tren pencatatan muzakki dan pembayaran</h2>
          <p class="analytics-description">Pilih metrik yang ingin ditampilkan untuk membaca pola jumlah muzakki, total pembayaran, atau total beras pada data terbaru.</p>
        </div>
        <div class="chart-switcher" role="tablist" aria-label="Pilih statistik dashboard">
          <button type="button" class="chart-switch is-active" data-chart-metric="total_muzakki">Muzakki</button>
          <button type="button" class="chart-switch" data-chart-metric="total_bayar">Pembayaran</button>
          <button type="button" class="chart-switch" data-chart-metric="total_beras_kg">Beras</button>
        </div>
      </div>

      <% if (overviewTrend.length > 0) { %>
        <div class="analytics-summary-bar">
          <div class="analytics-summary-item">
            <span class="analytics-summary-label" id="dashboardChartMetricLabel">Statistik Aktif</span>
            <strong class="analytics-summary-value" id="dashboardChartMetricValue"><%= latestTrendPoint ? `${latestTrendPoint.total_muzakki} data` : '0 data' %></strong>
          </div>
          <div class="analytics-summary-item">
            <span class="analytics-summary-label">Rentang Data</span>
            <strong class="analytics-summary-value"><%= chartRangeLabel %></strong>
          </div>
          <div class="analytics-summary-item">
            <span class="analytics-summary-label" id="dashboardChartPeakLabel">Puncak Harian</span>
            <strong class="analytics-summary-value" id="dashboardChartPeakValue">
              <% if (overviewInsights.peak_muzakki) { %>
                <%= overviewInsights.peak_muzakki.total_muzakki %> data / <%= overviewInsights.peak_muzakki.label || '-' %>
              <% } else { %>
                -
              <% } %>
            </strong>
          </div>
        </div>

        <div class="analytics-chart-wrap">
          <div class="analytics-chart-stage">
            <div class="chart-surface">
              <div class="chart-surface-glow chart-surface-glow-left" aria-hidden="true"></div>
              <div class="chart-surface-glow chart-surface-glow-right" aria-hidden="true"></div>

              <div class="chart-surface-header">
                <div class="chart-surface-heading">
                  <span class="chart-surface-kicker">Visual Tren Harian</span>
                  <h3 class="chart-surface-title" id="dashboardChartHeadline">Pergerakan jumlah muzakki per hari terakhir</h3>
                </div>
                <div class="chart-surface-badge" id="dashboardChartPeakBadge">
                  Puncak: <%= overviewInsights.peak_muzakki && overviewInsights.peak_muzakki.label ? overviewInsights.peak_muzakki.label : '-' %>
                </div>
              </div>

              <div class="chart-surface-body">
                <div class="chart-y-axis" id="dashboardChartYAxis" aria-hidden="true"></div>

                <div class="chart-plot-area">
                  <div class="chart-plot-overlay" aria-hidden="true"></div>
                  <svg id="dashboardTrendChart" class="dashboard-trend-chart" viewBox="0 0 760 320" preserveAspectRatio="none" role="img" aria-label="Grafik statistik muzakki"></svg>
                  <div id="dashboardChartTooltip" class="chart-tooltip" hidden></div>

                  <div class="chart-focus-card">
                    <span class="chart-focus-label" id="dashboardChartFocusLabel">Catatan terakhir</span>
                    <strong class="chart-focus-value" id="dashboardChartFocusValue">
                      <%= latestTrendPoint ? `${latestTrendPoint.total_muzakki} data` : '0 data' %>
                    </strong>
                    <p class="chart-focus-meta" id="dashboardChartFocusMeta">
                      <%= latestTrendPoint ? `Tercatat pada ${latestTrendPoint.label}` : 'Belum ada sorotan data' %>
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="chart-axis-labels">
            <% overviewTrend.forEach((item, index) => { %>
              <span data-axis-index="<%= index %>" class="<%= index === overviewTrend.length - 1 ? 'is-active' : '' %>"><%= item.label %></span>
            <% }); %>
          </div>
        </div>
      <% } else { %>
        <div class="empty-state analytics-empty-state">
          <div class="empty-icon">
            <i class="fas fa-chart-line"></i>
          </div>
          <h3 class="empty-title">Belum ada tren muzakki</h3>
          <p class="empty-desc">Grafik akan muncul otomatis setelah data muzakki mulai tercatat pada beberapa tanggal.</p>
        </div>
      <% } %>
    </div>

    <aside class="analytics-side-panel">
      <div class="insight-card">
        <span class="insight-label">Puncak Muzakki</span>
        <strong class="insight-value"><%= overviewInsights.peak_muzakki ? overviewInsights.peak_muzakki.total_muzakki : 0 %> data</strong>
        <p class="insight-note"><%= overviewInsights.peak_muzakki && overviewInsights.peak_muzakki.label ? overviewInsights.peak_muzakki.label : 'Belum ada data' %></p>
      </div>
      <div class="insight-card">
        <span class="insight-label">Puncak Pembayaran</span>
        <strong class="insight-value">Rp <%= Math.floor(overviewInsights.peak_bayar ? overviewInsights.peak_bayar.total_bayar : 0).toLocaleString('id-ID') %></strong>
        <p class="insight-note"><%= overviewInsights.peak_bayar && overviewInsights.peak_bayar.label ? overviewInsights.peak_bayar.label : 'Belum ada data' %></p>
      </div>
      <div class="insight-card">
        <span class="insight-label">Rata-rata Pembayaran</span>
        <strong class="insight-value">Rp <%= Math.floor(averageBayarPerMuzakki).toLocaleString('id-ID') %></strong>
        <p class="insight-note">Per nama muzakki yang tercatat</p>
      </div>
      <div class="insight-card insight-card-muted">
        <span class="insight-label">Cakupan Data</span>
        <strong class="insight-value"><%= overviewInsights.active_days || 0 %> hari</strong>
        <p class="insight-note"><%= stats.total_rt_aktif || 0 %> RT aktif dan <%= stats.total_users || 0 %> user pengelola</p>
      </div>
    </aside>
  </section>

  <script id="dashboardTrendData" type="application/json"><%- JSON.stringify(overviewTrend) %></script>

  <!-- Quick Actions Section - Revamped -->
  <div class="quick-actions-section">
    <div class="section-header">
      <div class="section-icon">
        <i class="fas fa-bolt"></i>
      </div>
      <h2 class="section-title">Quick Actions</h2>
      <span class="section-badge">Aksi Cepat</span>
    </div>
    
    <div class="quick-actions-grid">
      <a href="/muzakki/create" class="action-card action-primary">
        <div class="action-icon">
          <i class="fas fa-plus"></i>
        </div>
        <div class="action-content">
          <h3 class="action-title">Tambah Muzakki</h3>
          <p class="action-desc">Daftarkan muzakki baru</p>
        </div>
        <div class="action-arrow">
          <i class="fas fa-arrow-right"></i>
        </div>
      </a>

      <a href="/muzakki" class="action-card action-indigo">
        <div class="action-icon">
          <i class="fas fa-users"></i>
        </div>
        <div class="action-content">
          <h3 class="action-title">Data Muzakki</h3>
          <p class="action-desc">Lihat semua data</p>
        </div>
        <div class="action-arrow">
          <i class="fas fa-arrow-right"></i>
        </div>
      </a>

      <a href="/laporan" class="action-card action-green">
        <div class="action-icon">
          <i class="fas fa-chart-bar"></i>
        </div>
        <div class="action-content">
          <h3 class="action-title">Lihat Laporan</h3>
          <p class="action-desc">Analisis data lengkap</p>
        </div>
        <div class="action-arrow">
          <i class="fas fa-arrow-right"></i>
        </div>
      </a>
    </div>
  </div>

  <!-- Two Column Layout for Recent Data -->
  <div class="two-column-layout">
    <!-- Muzakki Terbaru Section - Revamped -->
    <div class="data-section">
      <div class="section-header">
        <div class="section-icon icon-blue">
          <i class="fas fa-user-plus"></i>
        </div>
        <div class="section-header-text">
          <h2 class="section-title">Muzakki Terbaru</h2>
          <p class="section-subtitle">Data pendaftaran terkini</p>
        </div>
        <span class="section-badge badge-blue">
          <i class="fas fa-clock"></i> Terbaru
        </span>
      </div>

      <div class="data-content">
        <% if (recentMuzakki && recentMuzakki.length > 0) { %>
          <div class="data-list">
            <% recentMuzakki.forEach((muzakki, index) => { %>
              <div class="data-item">
                <div class="data-item-number"><%= index + 1 %></div>
                <div class="data-item-content">
                  <div class="data-item-header">
                    <h3 class="data-item-name"><%= muzakki.nama %></h3>
                    <div class="data-item-amount">Rp <%= new Intl.NumberFormat('id-ID').format(muzakki.jumlah_zakat) %></div>
                  </div>
                  <div class="data-item-footer">
                    <div class="data-item-info">
                      <i class="fas fa-home"></i> RT <%= muzakki.rt_nama %>
                      <span class="separator">•</span>
                      <i class="fas fa-users"></i> <%= muzakki.jumlah_jiwa %> jiwa
                    </div>
                    <% if (muzakki.status === 'lunas') { %>
                      <span class="status-badge status-success">
                        <i class="fas fa-check-circle"></i> Lunas
                      </span>
                    <% } else { %>
                      <span class="status-badge status-warning">
                        <i class="fas fa-clock"></i> Belum Bayar
                      </span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
          
          <div class="section-footer">
            <a href="/muzakki" class="btn-view-all">
              <span>Lihat Semua Data</span>
              <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon">
              <i class="fas fa-users"></i>
            </div>
            <h3 class="empty-title">Belum ada data muzakki</h3>
            <p class="empty-desc">Mulai dengan mendaftarkan muzakki pertama</p>
            <a href="/muzakki/create" class="btn-empty-action">
              <i class="fas fa-plus"></i> Tambah Muzakki
            </a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Summary per RT Section - Revamped -->
    <div class="data-section">
      <div class="section-header">
        <div class="section-icon icon-green">
          <i class="fas fa-chart-pie"></i>
        </div>
        <div class="section-header-text">
          <h2 class="section-title">Summary per RT</h2>
          <p class="section-subtitle">Statistik berdasarkan RT</p>
        </div>
        <span class="section-badge badge-green">
          <i class="fas fa-chart-bar"></i> Statistik
        </span>
      </div>

      <div class="data-content">
        <% if (rtStats && rtStats.length > 0) { %>
          <div class="data-list">
            <% rtStats.forEach((rt, index) => { %>
              <div class="data-item">
                <div class="data-item-rt-icon">
                  <i class="fas fa-home"></i>
                </div>
                <div class="data-item-content">
                  <div class="data-item-header">
                    <h3 class="data-item-name">RT <%= rt.nomor_rt %></h3>
                    <div class="data-item-amount">Rp <%= Math.floor(rt.total_zakat).toLocaleString('id-ID') %></div>
                  </div>
                  <div class="data-item-footer">
                    <div class="data-item-info">
                      <i class="fas fa-users"></i> <%= rt.total_muzakki %> muzakki
                    </div>
                    <div class="rt-status-badges">
                      <span class="status-badge status-success-sm">
                        <%= rt.lunas %> lunas
                      </span>
                      <% if (rt.belum_bayar > 0) { %>
                        <span class="status-badge status-warning-sm">
                          <%= rt.belum_bayar %> belum
                        </span>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <h3 class="empty-title">Belum ada data statistik RT</h3>
            <p class="empty-desc">Data akan muncul setelah ada muzakki terdaftar</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Modern Dashboard Styles -->
<style>
  /* Dashboard Wrapper */
  .dashboard-wrapper {
    margin: 0 auto;
    width: 100%;
    max-width: 100%;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Modern Header */
  .dashboard-header {
    position: relative;
    background: linear-gradient(135deg, #1EAF2F 0%, #16a127 50%, #0f8a1f 100%);
    border-radius: 16px;
    padding: 24px 28px;
    box-shadow: 0 8px 24px rgba(30, 175, 47, 0.3);
    overflow: hidden;
  }

  .header-decoration {
    position: absolute;
    top: -50px;
    right: -50px;
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    animation: float 6s ease-in-out infinite;
  }

  .header-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 20px;
    min-width: 0;
  }

  .header-text {
    min-width: 0;
  }

  .header-icon-wrapper {
    width: 72px;
    height: 72px;
    background: white;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    padding: 10px;
  }

  .header-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .header-title {
    font-size: 28px;
    font-weight: 700;
    color: white;
    margin: 0;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .header-subtitle {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    margin-top: 4px;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .header-name {
    font-weight: 600;
    color: #fbbf24;
  }

  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    max-width: 100%;
  }

  .calendar-combined-card {
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 10px;
    padding: 10px 12px;
    color: #ffffff;
    width: 100%;
    max-width: 330px;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .calendar-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .calendar-row-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.32px;
    color: #dcfce7;
    text-transform: uppercase;
  }

  .calendar-row-value {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .calendar-row-subvalue {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

