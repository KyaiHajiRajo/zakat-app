  .stats-grid-modern {
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 14px;
  }

  .stats-grid-modern .stat-card {
    grid-column: span 3;
    border-radius: 20px;
    padding: 18px;
    min-height: 198px;
    border: 1px solid rgba(219, 231, 225, 0.95);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
  }

  .stats-grid-modern .stat-card::after {
    content: "";
    position: absolute;
    inset: auto -20px -36px auto;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0) 72%);
    pointer-events: none;
  }

  .stats-grid-modern .stat-card-featured {
    grid-column: span 6;
    min-height: 220px;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.35), transparent 34%),
      linear-gradient(135deg, #14863a 0%, #0f7a50 55%, #0f766e 100%);
    border-color: transparent;
    color: #ffffff;
  }

  .stat-card-identity {
    display: flex;
    align-items: center;
    gap: 12px;
