<!-- Enhanced JavaScript -->
<script>
  const dashboardTrendDataElement = document.getElementById('dashboardTrendData');
  let dashboardTrendData = [];

  if (dashboardTrendDataElement) {
    try {
      dashboardTrendData = JSON.parse(dashboardTrendDataElement.textContent || '[]');
    } catch (error) {
      dashboardTrendData = [];
    }
  }

  function formatDashboardChartValue(metric, value) {
    const safeValue = Number(value || 0);

    if (metric === 'total_bayar') {
      return `Rp ${Math.round(safeValue).toLocaleString('id-ID')}`;
    }

    if (metric === 'total_beras_kg') {
      return `${new Intl.NumberFormat('id-ID', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 2
      }).format(safeValue)} kg`;
    }

    return `${Math.round(safeValue).toLocaleString('id-ID')} data`;
  }

  function getDashboardChartMetricConfig(metric) {
    const metricMap = {
      total_muzakki: {
        label: 'Catatan Terbaru',
        headline: 'Pergerakan jumlah muzakki per hari terakhir',
        peakLabel: 'Puncak Muzakki',
        lineColor: '#16a34a',
        lineGlow: 'rgba(22, 163, 74, 0.24)',
        areaColorStart: 'rgba(22, 163, 74, 0.32)',
        areaColorEnd: 'rgba(34, 197, 94, 0.02)',
        pointColor: '#166534',
        pointHalo: 'rgba(22, 163, 74, 0.18)',
        badgeTone: 'rgba(220, 252, 231, 0.92)'
      },
      total_bayar: {
        label: 'Catatan Terbaru',
        headline: 'Pola pembayaran zakat harian yang sudah masuk',
        peakLabel: 'Puncak Pembayaran',
        lineColor: '#0f766e',
        lineGlow: 'rgba(15, 118, 110, 0.24)',
        areaColorStart: 'rgba(15, 118, 110, 0.28)',
        areaColorEnd: 'rgba(45, 212, 191, 0.02)',
        pointColor: '#115e59',
        pointHalo: 'rgba(15, 118, 110, 0.18)',
        badgeTone: 'rgba(204, 251, 241, 0.92)'
      },
      total_beras_kg: {
        label: 'Catatan Terbaru',
        headline: 'Pergerakan stok beras zakat yang tercatat per hari',
        peakLabel: 'Puncak Beras',
        lineColor: '#ea580c',
        lineGlow: 'rgba(234, 88, 12, 0.22)',
        areaColorStart: 'rgba(234, 88, 12, 0.24)',
        areaColorEnd: 'rgba(251, 146, 60, 0.02)',
        pointColor: '#c2410c',
        pointHalo: 'rgba(234, 88, 12, 0.16)',
        badgeTone: 'rgba(255, 237, 213, 0.92)'
      }
    };

    return metricMap[metric] || metricMap.total_muzakki;
  }

  function formatDashboardChartShortValue(metric, value) {
    const safeValue = Number(value || 0);

    if (metric === 'total_bayar') {
      if (safeValue >= 1000000) {
        return `Rp ${(safeValue / 1000000).toFixed(safeValue % 1000000 === 0 ? 0 : 1)} jt`;
      }

      if (safeValue >= 1000) {
        return `Rp ${(safeValue / 1000).toFixed(safeValue % 1000 === 0 ? 0 : 1)} rb`;
      }

      return `Rp ${Math.round(safeValue).toLocaleString('id-ID')}`;
    }

    if (metric === 'total_beras_kg') {
      return `${new Intl.NumberFormat('id-ID', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 1
      }).format(safeValue)} kg`;
    }

    return `${Math.round(safeValue).toLocaleString('id-ID')} data`;
  }

  function buildDashboardLinePath(points) {
    if (!points.length) {
      return '';
    }

    if (points.length === 1) {
      return `M ${points[0].x} ${points[0].y}`;
    }

    let path = `M ${points[0].x} ${points[0].y}`;

    for (let index = 0; index < points.length - 1; index += 1) {
      const currentPoint = points[index];
      const nextPoint = points[index + 1];
      const controlPointX = Number(((currentPoint.x + nextPoint.x) / 2).toFixed(2));

      path += ` C ${controlPointX} ${currentPoint.y}, ${controlPointX} ${nextPoint.y}, ${nextPoint.x} ${nextPoint.y}`;
    }

    return path;
  }

  function renderDashboardTrendChart(metric = 'total_muzakki') {
    const svg = document.getElementById('dashboardTrendChart');
    const tooltip = document.getElementById('dashboardChartTooltip');
    const metricLabelElement = document.getElementById('dashboardChartMetricLabel');
    const metricValueElement = document.getElementById('dashboardChartMetricValue');
    const peakLabelElement = document.getElementById('dashboardChartPeakLabel');
    const peakValueElement = document.getElementById('dashboardChartPeakValue');
    const headlineElement = document.getElementById('dashboardChartHeadline');
    const peakBadgeElement = document.getElementById('dashboardChartPeakBadge');
    const yAxisElement = document.getElementById('dashboardChartYAxis');
    const focusLabelElement = document.getElementById('dashboardChartFocusLabel');
    const focusValueElement = document.getElementById('dashboardChartFocusValue');
    const focusMetaElement = document.getElementById('dashboardChartFocusMeta');
    const switches = document.querySelectorAll('.chart-switch');
    const axisLabels = document.querySelectorAll('.chart-axis-labels span');

    if (!svg || !dashboardTrendData.length) {
      return;
    }

    const config = getDashboardChartMetricConfig(metric);
    const width = 760;
    const height = 320;
    const padding = { top: 24, right: 22, bottom: 34, left: 16 };
    const plotWidth = width - padding.left - padding.right;
    const plotHeight = height - padding.top - padding.bottom;
    const values = dashboardTrendData.map((item) => Number(item[metric] || 0));
    const maxValue = Math.max(...values, 1);

    const points = values.map((value, index) => {
      const x =
        values.length === 1
          ? padding.left + plotWidth / 2
          : padding.left + (plotWidth * index) / (values.length - 1);
      const y = padding.top + plotHeight - (value / maxValue) * plotHeight;
      return {
        x: Number(x.toFixed(2)),
        y: Number(y.toFixed(2)),
        value,
        item: dashboardTrendData[index],
      };
    });

    const baselineY = padding.top + plotHeight;
    const linePath = buildDashboardLinePath(points);
    const areaPath = points.length
      ? `${linePath} L ${points[points.length - 1].x} ${baselineY} L ${points[0].x} ${baselineY} Z`
      : '';
    const latestPoint = points[points.length - 1];
    const peakPoint = points.reduce((bestPoint, point) => {
      if (!bestPoint || point.value > bestPoint.value) {
        return point;
      }

      return bestPoint;
    }, null) || latestPoint;

    const guideLines = Array.from({ length: 5 }, (_, index) => {
      const ratio = index / 4;
      const y = padding.top + plotHeight - ratio * plotHeight;
      return `
        <line x1="${padding.left}" y1="${y}" x2="${width - padding.right}" y2="${y}" stroke="rgba(148, 163, 184, 0.2)" stroke-dasharray="4 8" />
      `;
    }).join('');

    const pointMarkers = points.map((point, index) => `
      <circle cx="${point.x}" cy="${point.y}" r="6" fill="${config.pointColor}" stroke="#ffffff" stroke-width="3"></circle>
      <circle
        class="chart-hit-point"
        data-point-index="${index}"
        cx="${point.x}"
        cy="${point.y}"
        r="16"
        fill="transparent"
        tabindex="0"
        role="button"
        aria-label="${point.item.label}: ${formatDashboardChartValue(metric, point.value)}"
        style="cursor: pointer;"
      ></circle>
    `).join('');

    if (yAxisElement) {
      yAxisElement.innerHTML = Array.from({ length: 5 }, (_, index) => {
        const ratio = (4 - index) / 4;
        const labelValue = maxValue * ratio;

        return `<div class="chart-y-axis-item">${formatDashboardChartShortValue(metric, labelValue)}</div>`;
      }).join('');
    }

    svg.innerHTML = `
      <defs>
        <linearGradient id="dashboardAreaGradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${config.areaColorStart}" />
          <stop offset="100%" stop-color="${config.areaColorEnd}" />
        </linearGradient>
        <filter id="dashboardLineGlow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="12" stdDeviation="10" flood-color="${config.lineGlow}" flood-opacity="1" />
        </filter>
      </defs>
      ${guideLines}
      <line id="dashboardChartActiveGuide" x1="${latestPoint.x}" y1="${padding.top}" x2="${latestPoint.x}" y2="${baselineY}" stroke="${config.lineGlow}" stroke-width="1.5" stroke-dasharray="5 8"></line>
      <path d="${areaPath}" fill="url(#dashboardAreaGradient)"></path>
      <path d="${linePath}" fill="none" stroke="${config.lineColor}" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" filter="url(#dashboardLineGlow)"></path>
      <circle id="dashboardChartActiveHalo" cx="${latestPoint.x}" cy="${latestPoint.y}" r="13" fill="${config.pointHalo}"></circle>
      <circle id="dashboardChartActiveDot" cx="${latestPoint.x}" cy="${latestPoint.y}" r="7" fill="${config.pointColor}" stroke="#ffffff" stroke-width="3"></circle>
      ${pointMarkers}
    `;

    if (metricLabelElement) {
      metricLabelElement.textContent = config.label;
    }

    if (metricValueElement) {
      metricValueElement.textContent = formatDashboardChartValue(metric, latestPoint.value);
    }

    if (peakLabelElement) {
      peakLabelElement.textContent = config.peakLabel;
    }

    if (peakValueElement) {
      peakValueElement.textContent = `${formatDashboardChartValue(metric, peakPoint.value)} / ${peakPoint.item.label}`;
    }

    if (headlineElement) {
      headlineElement.textContent = config.headline;
    }

    if (peakBadgeElement) {
      peakBadgeElement.textContent = `${config.peakLabel}: ${peakPoint.item.label}`;
      peakBadgeElement.style.background = config.badgeTone;
      peakBadgeElement.style.borderColor = config.lineGlow;
    }

    switches.forEach((button) => {
      button.classList.toggle('is-active', button.dataset.chartMetric === metric);
    });

    const setActivePointVisual = (point) => {
      const activeGuide = document.getElementById('dashboardChartActiveGuide');
      const activeHalo = document.getElementById('dashboardChartActiveHalo');
      const activeDot = document.getElementById('dashboardChartActiveDot');

      if (activeGuide) {
        activeGuide.setAttribute('x1', point.x);
        activeGuide.setAttribute('x2', point.x);
      }

      if (activeHalo) {
        activeHalo.setAttribute('cx', point.x);
        activeHalo.setAttribute('cy', point.y);
        activeHalo.setAttribute('fill', config.pointHalo);
      }

      if (activeDot) {
        activeDot.setAttribute('cx', point.x);
        activeDot.setAttribute('cy', point.y);
        activeDot.setAttribute('fill', config.pointColor);
      }
    };

    const setActiveAxisLabel = (activeIndex) => {
      axisLabels.forEach((element) => {
        element.classList.toggle('is-active', Number(element.dataset.axisIndex) === activeIndex);
      });
    };

    const updateFocusCard = (point, stateLabel = 'Catatan terakhir') => {
      if (focusLabelElement) {
        focusLabelElement.textContent = stateLabel;
      }

      if (focusValueElement) {
        focusValueElement.textContent = formatDashboardChartValue(metric, point.value);
      }

      if (focusMetaElement) {
        focusMetaElement.textContent = `${point.item.label} / Muzakki ${Math.round(Number(point.item.total_muzakki || 0)).toLocaleString('id-ID')} / Pembayaran ${formatDashboardChartShortValue('total_bayar', point.item.total_bayar)} / Beras ${formatDashboardChartShortValue('total_beras_kg', point.item.total_beras_kg)}`;
      }
    };

    const showTooltip = (point) => {
      if (!tooltip) {
        return;
      }

      setActivePointVisual(point);
      setActiveAxisLabel(dashboardTrendData.indexOf(point.item));
      updateFocusCard(point, 'Sorotan titik aktif');
      tooltip.hidden = false;
      tooltip.innerHTML = `
        <span class="chart-tooltip-date">${point.item.label}</span>
        <div class="chart-tooltip-value">${formatDashboardChartValue(metric, point.value)}</div>
        <div class="chart-tooltip-meta">
          <span>Muzakki: ${formatDashboardChartValue('total_muzakki', point.item.total_muzakki)}</span>
          <span>Pembayaran: ${formatDashboardChartValue('total_bayar', point.item.total_bayar)}</span>
          <span>Beras: ${formatDashboardChartValue('total_beras_kg', point.item.total_beras_kg)}</span>
        </div>
      `;
      tooltip.style.left = `${(point.x / width) * 100}%`;
      tooltip.style.top = `${(point.y / height) * 100}%`;
    };

    const hideTooltip = () => {
      if (tooltip) {
        tooltip.hidden = true;
      }

      setActivePointVisual(latestPoint);
      setActiveAxisLabel(points.length - 1);
      updateFocusCard(latestPoint, 'Catatan terakhir');
    };

    setActivePointVisual(latestPoint);
    setActiveAxisLabel(points.length - 1);
    updateFocusCard(latestPoint, 'Catatan terakhir');

    svg.querySelectorAll('.chart-hit-point').forEach((element) => {
      element.addEventListener('mouseenter', () => {
        const pointIndex = Number(element.getAttribute('data-point-index'));
        if (Number.isInteger(pointIndex) && points[pointIndex]) {
          showTooltip(points[pointIndex]);
        }
      });

      element.addEventListener('mouseleave', hideTooltip);
      element.addEventListener('focus', () => {
        const pointIndex = Number(element.getAttribute('data-point-index'));
        if (Number.isInteger(pointIndex) && points[pointIndex]) {
          showTooltip(points[pointIndex]);
        }
      });
      element.addEventListener('blur', hideTooltip);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const dateElement = document.getElementById('current-date');
    const hijriDateElement = document.getElementById('current-hijri-date');
    const hijriDetailElement = document.getElementById('current-hijri-detail');
    const HIJRI_DAY_ADJUSTMENT = -1;

    function formatHijriDate(date) {
      const adjustedDate = new Date(date);
      adjustedDate.setDate(adjustedDate.getDate() + HIJRI_DAY_ADJUSTMENT);

      const calendarFallbacks = ['islamic-umalqura', 'islamic', 'islamic-civil'];
      for (const calendarType of calendarFallbacks) {
        try {
          const mainFormatter = new Intl.DateTimeFormat('id-ID', {
            calendar: calendarType,
            day: 'numeric',
            month: 'long',
            year: 'numeric'
          });
          const detailFormatter = new Intl.DateTimeFormat('id-ID', {
            calendar: calendarType,
            weekday: 'long'
          });

          return {
            main: mainFormatter.format(adjustedDate),
            detail: detailFormatter.format(adjustedDate)
          };
        } catch (err) {
          // Try next Islamic calendar variant when not supported by browser.
        }
      }

      return null;
    }

    if (dateElement) {
      const now = new Date();
      const options = {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      };
      dateElement.textContent = now.toLocaleDateString('id-ID', options);

      if (hijriDateElement) {
        const hijriFormatted = formatHijriDate(now);
        if (hijriFormatted) {
          hijriDateElement.textContent = hijriFormatted.main;
          if (hijriDetailElement) {
            hijriDetailElement.textContent = `${hijriFormatted.detail} (Hijriyah)`;
          }
        } else {
          hijriDateElement.textContent = 'Kalender Hijriyah tidak didukung browser';
          if (hijriDetailElement) {
            hijriDetailElement.textContent = 'Silakan gunakan browser modern terbaru';
          }
        }
      }
    }

    const animateElements = document.querySelectorAll('.stat-card, .action-card, .data-item, .insight-card, .analytics-summary-item');
    animateElements.forEach((el, index) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      setTimeout(() => {
        el.style.transition = 'all 0.5s ease';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, index * 50);
    });

    const importantElements = document.querySelectorAll("[data-islamic-glow]");
    importantElements.forEach(el => {
      el.classList.add("islamic-glow");
    });

    const tooltips = document.querySelectorAll("[data-tooltip]");
    tooltips.forEach(el => {
      el.addEventListener("mouseenter", function() {
        this.style.transform = "scale(1.05)";
      });
      el.addEventListener("mouseleave", function() {
        this.style.transform = "scale(1)";
      });
    });

    if (dashboardTrendData.length > 0) {
      renderDashboardTrendChart('total_muzakki');

      document.querySelectorAll('.chart-switch').forEach((button) => {
        button.addEventListener('click', function () {
          renderDashboardTrendChart(this.dataset.chartMetric || 'total_muzakki');
        });
      });
    }

    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener("click", function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute("href"));
        if (target) {
          target.scrollIntoView({
            behavior: "smooth",
            block: "start"
          });
        }
      });
    });

    const buttons = document.querySelectorAll("button, .btn-gradient-emerald, .btn-gradient-teal, .btn-gradient-cyan");
    buttons.forEach(button => {
      button.addEventListener("click", function(e) {
        const ripple = document.createElement("span");
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;

        ripple.style.width = ripple.style.height = size + "px";
        ripple.style.left = x + "px";
        ripple.style.top = y + "px";
        ripple.classList.add("ripple");

        this.appendChild(ripple);

        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    });
  });

  setInterval(() => {
    const statsCards = document.querySelectorAll("[data-stat-card]");
    statsCards.forEach(card => {
      card.classList.add("animate-pulse");
      setTimeout(() => {
        card.classList.remove("animate-pulse");
      }, 1000);
    });
  }, 300000);
</script>

<%- include('layouts/footer') %>
