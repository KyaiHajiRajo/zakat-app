    gap: 10px;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .overview-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid #d9e7dd;
    color: #14532d;
    font-size: 12px;
    font-weight: 700;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
