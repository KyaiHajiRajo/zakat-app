  /* Dashboard Overview Refresh */
  .overview-shell,
  .analytics-main-card,
  .analytics-side-panel {
    position: relative;
    border: 1px solid #dbe7e1;
    border-radius: 22px;
    background:
      radial-gradient(circle at top right, rgba(22, 163, 74, 0.08), transparent 34%),
      linear-gradient(180deg, #ffffff 0%, #f8fbf7 100%);
