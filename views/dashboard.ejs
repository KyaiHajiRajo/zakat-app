  .analytics-chart-wrap {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .analytics-chart-stage {
    border-radius: 28px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(243, 248, 245, 0.94)),
      radial-gradient(circle at top left, rgba(34, 197, 94, 0.16), transparent 34%);
    border: 1px solid rgba(207, 226, 214, 0.9);
    box-shadow: 0 24px 52px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .chart-surface {
    position: relative;
    min-height: 396px;
    padding: 20px;
